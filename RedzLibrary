        local LabelTitle = InsertTheme(Create("TextLabel", TabSelect, {
            Size             = UDim2.new(1, TIcon and -25 or -15, 1),
            Position         = UDim2.fromOffset(TIcon and 25 or 15),
            BackgroundTransparency = 1,
