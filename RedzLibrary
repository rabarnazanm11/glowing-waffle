                TextColor3           = Theme["Color Text"],
                ClearTextOnFocus     = TClear,
                PlaceholderText      = TPlaceholder,
                Text                 = TDefault,
            }), "Text")
            local Pencil = Create("ImageLabel", SelectedFrame, {
                Size                 = UDim2.new(0, 12, 0, 12),
                Position             = UDim2.new(0, -5, 0.5),
                AnchorPoint          = Vector2.new(1, 0.5),
                Image                = "rbxassetid://15637081879",
                BackgroundTransparency = 1,
            })
            local TextBox = {}
            local function CommitInput()
                local text = TextBoxInput.Text
                if text:gsub(" ", "") ~= "" then
                    if TextBox.OnChanging then text = TextBox.OnChanging(text) or text end
                    Funcs:FireCallback(Callback, text)
                    TextBoxInput.Text = text
                end
            end
            TextBoxInput.FocusLost:Connect(CommitInput)
            TextBoxInput.FocusLost:Connect(function()
                CreateTween({ Pencil, "ImageColor3", Color3.fromRGB(255,255,255), 0.2 })
            end)
            TextBoxInput.Focused:Connect(function()
                CreateTween({ Pencil, "ImageColor3", Theme["Color Theme"], 0.2 })
            end)
            TextBox.OnChanging = false
            function TextBox:Visible(...)  Funcs:ToggleVisible(Button, ...) end
            function TextBox:Destroy()     Button:Destroy()                 end
            function TextBox:Set(val)
                if type(val) == "string" then TextBoxInput.Text = val end
            end
            return TextBox
        end

        -- ‚ĒÄ‚ĒÄ AddKeybind ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        function Tab:AddKeybind(Configs)
            local KName    = Configs[1] or Configs.Name  or Configs.Title or "Keybind"
            local KDesc    = Configs.Desc or Configs.Description or ""
            local Default  = Configs[2] or Configs.Default or Enum.KeyCode.Unknown
            local Flag     = Configs[4] or Configs.Flag or false
            local Callback = Funcs:GetCallback(Configs, 3)
            if CheckFlag(Flag) then
                local saved = GetFlag(Flag)
                if type(saved) == "string" and Enum.KeyCode[saved] then
                    Default = Enum.KeyCode[saved]
                end
            end
            local CurrentKey = Default
            local Listening  = false
            local Button, LabelFunc = ButtonFrame(Container, KName, KDesc, UDim2.new(1, -100))
            local KeyHolder = InsertTheme(Create("TextButton", Button, {
                Size             = UDim2.new(0, 80, 0, 18),
                Position         = UDim2.new(1, -10, 0.5),
                AnchorPoint      = Vector2.new(1, 0.5),
                BackgroundColor3 = Theme["Color Stroke"],
                Font             = Enum.Font.GothamBold,
                TextSize         = 9,
                TextColor3       = Theme["Color Text"],
                Text             = CurrentKey.Name,
                AutoButtonColor  = false,
            }), "Stroke")
            Make("Corner", KeyHolder, UDim.new(0, 4))
            local function SetKey(key)
                CurrentKey     = key
                KeyHolder.Text = key.Name
                Listening      = false
                CreateTween({ KeyHolder, "BackgroundColor3", Theme["Color Stroke"], 0.15 })
                SetFlag(Flag, key.Name)
                Funcs:FireCallback(Callback, key)
            end
            KeyHolder.Activated:Connect(function()
                if Listening then
                    Listening      = false
                    KeyHolder.Text = CurrentKey.Name
                    CreateTween({ KeyHolder, "BackgroundColor3", Theme["Color Stroke"], 0.15 })
                else
                    Listening      = true
                    KeyHolder.Text = "..."
                    CreateTween({ KeyHolder, "BackgroundColor3", Theme["Color Theme"], 0.15 })
                end
            end)
            UserInputService.InputBegan:Connect(function(input, gpe)
                if not Listening then return end
                if gpe then return end
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    SetKey(input.KeyCode)
                end
            end)
            local Keybind = {}
            function Keybind:Set(val)
                if typeof(val) == "EnumItem" then SetKey(val)
                elseif type(val) == "string" and Enum.KeyCode[val] then SetKey(Enum.KeyCode[val]) end
            end
            function Keybind:GetKey()     return CurrentKey                         end
            function Keybind:Visible(...) Funcs:ToggleVisible(Button, ...)          end
            function Keybind:Destroy()    Button:Destroy()                          end
            return Keybind
        end

