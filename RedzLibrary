local function CreateTween(Configs)
    local Inst   = Configs[1] or Configs.Instance
    local Prop   = Configs[2] or Configs.Prop
    local NewVal = Configs[3] or Configs.NewVal
    local Time   = Configs[4] or Configs.Time or 0.5
    local DoWait = Configs[5] or Configs.wait or false
    local Tween  = TweenService:Create(Inst, TweenInfo.new(Time, Enum.EasingStyle.Quint), { [Prop] = NewVal })
    Tween:Play()
    if DoWait then Tween.Completed:Wait() end
    return Tween
end
local function SaveJson(FileName, data)
    if not rawget(_G, "writefile") then return end
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then pcall(_G.writefile, FileName, encoded) end
end

-- Drag helpers
local function MakeWindowDrag(Inst, TabScrollFrame, TopBar)
    task.spawn(function()
        SetProps(Inst, { Active = true, AutoButtonColor = false })
        local Dragging, DragStart, StartPos = false, nil, nil
        Inst.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
            and input.UserInputType ~= Enum.UserInputType.Touch then return end
            local mousePos = UserInputService:GetMouseLocation()
            if TabScrollFrame and TabScrollFrame.Visible then
                local absPos  = TabScrollFrame.AbsolutePosition
                local absSize = TabScrollFrame.AbsoluteSize
                if mousePos.X >= absPos.X - 5 and mousePos.X <= absPos.X + absSize.X + 5
                and mousePos.Y >= absPos.Y - 5 and mousePos.Y <= absPos.Y + absSize.Y + 5 then
                    return
                end
            end
            if TopBar then
                local topBarPos  = TopBar.AbsolutePosition
                local topBarSize = TopBar.AbsoluteSize
                local inTopBar   = mousePos.X >= topBarPos.X and mousePos.X <= topBarPos.X + topBarSize.X
                               and mousePos.Y >= topBarPos.Y and mousePos.Y <= topBarPos.Y + topBarSize.Y
                if not inTopBar then return end
            end
            Dragging  = true
            DragStart = mousePos
            StartPos  = Inst.Position
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                Dragging = false
            end
        end)
        RunService.Heartbeat:Connect(function()
            if not Dragging then return end
            local delta = UserInputService:GetMouseLocation() - DragStart
            Inst.Position = UDim2.new(
                StartPos.X.Scale, StartPos.X.Offset + delta.X / UIScale,
                StartPos.Y.Scale, StartPos.Y.Offset + delta.Y / UIScale
            )
        end)
    end)
    return Inst
end

local function MakeDrag(Inst)
    task.spawn(function()
        SetProps(Inst, { Active = true, AutoButtonColor = false })
        local Dragging, DragStart, StartPos = false, nil, nil
        Inst.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
            and input.UserInputType ~= Enum.UserInputType.Touch then return end
            Dragging  = true
            DragStart = UserInputService:GetMouseLocation()
            StartPos  = Inst.Position
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                Dragging = false
            end
        end)
        RunService.Heartbeat:Connect(function()
            if not Dragging then return end
            local delta = UserInputService:GetMouseLocation() - DragStart
            Inst.Position = UDim2.new(
                StartPos.X.Scale, StartPos.X.Offset + delta.X / UIScale,
                StartPos.Y.Scale, StartPos.Y.Offset + delta.Y / UIScale
            )
        end)
    end)
    return Inst
end

local function ConnectSave(Inst, func)
    Inst.InputBegan:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1
        and Input.UserInputType ~= Enum.UserInputType.Touch then return end
        task.spawn(function()
            while UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                task.wait()
            end
            func()
        end)
    end)
end

local function VerifyTheme(Theme)
    return redzlib.Themes[Theme] ~= nil
end
local Theme = redzlib.Themes[redzlib.Save.Theme]

local function GetColor(Inst)
    if Inst:IsA("Frame")          then return "BackgroundColor3"
    elseif Inst:IsA("ImageLabel") then return "ImageColor3"
    elseif Inst:IsA("TextLabel")  then return "TextColor3"
    elseif Inst:IsA("TextButton") then return "BackgroundColor3"
    elseif Inst:IsA("ScrollingFrame") then return "ScrollBarImageColor3"
    elseif Inst:IsA("UIStroke")   then return "Color"
    end
    return ""
end

