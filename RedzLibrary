    function Window:MakeFloatButton(icon)
        local iconId = redzlib:GetIcon(type(icon) == "string" and icon or "sword")
        local FloatGui = Instance.new("ScreenGui")
        FloatGui.Name           = "FloatHubBtn"
        FloatGui.ResetOnSpawn   = false
        FloatGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
        FloatGui.IgnoreGuiInset = true
        FloatGui.DisplayOrder   = 999
        FloatGui.Parent         = CoreGui
        local Pill = Instance.new("TextButton")
        Pill.Name                   = "FloatPill"
        Pill.Size                   = UDim2.fromOffset(42, 42)
        Pill.Position               = UDim2.fromOffset(30, 50)
        Pill.AnchorPoint            = Vector2.new(0, 0.5)
        Pill.BackgroundColor3       = Color3.fromRGB(18, 18, 18)
        Pill.AutoButtonColor        = false
        Pill.Active                 = true
        Pill.Text                   = ""
        Pill.ZIndex                 = 5
        Pill.Parent                 = FloatGui
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0.5, 0)
        corner.Parent = Pill
        local stroke = Instance.new("UIStroke")
        stroke.Color           = Color3.fromRGB(88, 101, 242)
        stroke.Thickness       = 1.8
        stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        stroke.Parent          = Pill
        local grad = Instance.new("UIGradient")
        grad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(28, 28, 28)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(38, 38, 48)),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(18, 18, 18)),
        })
        grad.Rotation = 90
        grad.Parent   = Pill
        local Icon = Instance.new("ImageLabel")
        Icon.Size                   = UDim2.fromOffset(22, 22)
        Icon.Position               = UDim2.fromScale(0.5, 0.5)
        Icon.AnchorPoint            = Vector2.new(0.5, 0.5)
        Icon.BackgroundTransparency = 1
        Icon.Image                  = iconId
        Icon.ImageColor3            = Color3.fromRGB(88, 101, 242)
        Icon.ZIndex                 = 6
        Icon.Parent                 = Pill
        task.spawn(function()
            while FloatGui.Parent do
                TweenService:Create(stroke, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { Transparency = 0.55 }):Play()
                task.wait(1.4)
                TweenService:Create(stroke, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { Transparency = 0 }):Play()
                task.wait(1.4)
            end
        end)
        Pill.MouseEnter:Connect(function()
            TweenService:Create(Pill,   TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(30, 30, 45) }):Play()
            TweenService:Create(stroke, TweenInfo.new(0.15), { Transparency = 0 }):Play()
            TweenService:Create(Icon,   TweenInfo.new(0.15), { ImageColor3 = Color3.fromRGB(160, 170, 255) }):Play()
        end)
        Pill.MouseLeave:Connect(function()
            TweenService:Create(Pill, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(18, 18, 18) }):Play()
            TweenService:Create(Icon, TweenInfo.new(0.15), { ImageColor3 = Color3.fromRGB(88, 101, 242) }):Play()
        end)
        local THRESHOLD   = 10
        local pressing    = false
        local wasDragged  = false
        local dragStart   = nil
        local startOffset = nil
        Pill.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
            and input.UserInputType ~= Enum.UserInputType.Touch then return end
            pressing    = true
            wasDragged  = false
            dragStart   = UserInputService:GetMouseLocation()
            startOffset = Vector2.new(Pill.Position.X.Offset, Pill.Position.Y.Offset)
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
            and input.UserInputType ~= Enum.UserInputType.Touch then return end
            if not pressing then return end
            if not wasDragged then
                TweenService:Create(Pill, TweenInfo.new(0.08), { BackgroundColor3 = Color3.fromRGB(88, 101, 242) }):Play()
                task.delay(0.08, function()
                    TweenService:Create(Pill, TweenInfo.new(0.2), { BackgroundColor3 = Color3.fromRGB(18, 18, 18) }):Play()
                end)
                Window:Minimize()
            end
            pressing = false; wasDragged = false; dragStart = nil
        end)
        RunService.Heartbeat:Connect(function()
            if not pressing or not dragStart then return end
            local delta = UserInputService:GetMouseLocation() - dragStart
            if delta.Magnitude >= THRESHOLD then
                wasDragged    = true
                Pill.Position = UDim2.fromOffset(startOffset.X + delta.X, startOffset.Y + delta.Y)
            end
        end)
        return Pill
    end

