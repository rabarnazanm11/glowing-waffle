    local function LoadFile()
        local File = Settings.ScriptFile
        if type(File) ~= "string" then return end
        if not rawget(_G, "readfile") or not rawget(_G, "isfile") then return end
        local ok, exists = pcall(_G.isfile, File)
        if not ok or not exists then return end
        local ok2, raw = pcall(_G.readfile, File)
        if not ok2 then return end
        local ok3, decoded = pcall(HttpService.JSONDecode, HttpService, raw)
        if ok3 and type(decoded) == "table" then
            for k, v in pairs(decoded) do
                if type(v) ~= "function" then Flags[k] = v end
            end
        end
    end
    LoadFile()

