            Text             = TName,
            TextColor3       = Theme["Color Text"],
            TextSize         = 10,
            TextXAlignment   = Enum.TextXAlignment.Left,
            TextTransparency = isFirst and 0 or 0.3,
            TextTruncate     = "AtEnd",
