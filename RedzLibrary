            Position         = UDim2.new(0, 8, 0.5),
            Size             = UDim2.new(0, 13, 0, 13),
            AnchorPoint      = Vector2.new(0, 0.5),
            Image            = TIcon or "",
            BackgroundTransparency = 1,
            ImageTransparency = isFirst and 0 or 0.3,
