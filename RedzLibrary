        -- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
        function Tab:AddColorPicker(Configs)
            local CName    = Configs[1] or Configs.Name  or Configs.Title or "Color"
            local CDesc    = Configs.Desc or Configs.Description or ""
            local Default  = Configs[2] or Configs.Default or Color3.fromRGB(255, 255, 255)
            local Flag     = Configs[4] or Configs.Flag    or false
            local Callback = Funcs:GetCallback(Configs, 3)

            -- Restore from saved flag ({r=, g=, b=} table)
            if CheckFlag(Flag) then
                local saved = GetFlag(Flag)
                if type(saved) == "table" and saved.r then
                    Default = Color3.new(
                        math.clamp(tonumber(saved.r) or 1, 0, 1),
                        math.clamp(tonumber(saved.g) or 1, 0, 1),
                        math.clamp(tonumber(saved.b) or 1, 0, 1)
                    )
                end
            end

            local curH, curS, curV = Color3.toHSV(Default)
            local currentColor     = Default

            -- Layout constants
            local PANEL_H  = 148
            local SV_SZ    = 108
            local HUE_W    = 14
            local MARGIN   = 8
            local INFO_X   = MARGIN + SV_SZ + 6 + HUE_W + 8

            -- ‚ĒÄ‚ĒÄ Header button row ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

            local Button, LabelFunc = ButtonFrame(Container, CName, CDesc, UDim2.new(1, -50))

            -- Coloured swatch pill on the right
            local Swatch = Create("Frame", Button, {
                Size             = UDim2.new(0, 28, 0, 16),
                Position         = UDim2.new(1, -10, 0.5),
                AnchorPoint      = Vector2.new(1, 0.5),
                BackgroundColor3 = currentColor,
                BorderSizePixel  = 0,
            })
            Make("Corner", Swatch, UDim.new(0, 4))
            Make("Stroke",  Swatch)

            local Arrow = Create("ImageLabel", Button, {
                Size                 = UDim2.new(0, 12, 0, 12),
                Position             = UDim2.new(1, -43, 0.5),
                AnchorPoint          = Vector2.new(0, 0.5),
                BackgroundTransparency = 1,
                Image                = "rbxassetid://10709791523",
            })

            -- ‚ĒÄ‚ĒÄ Expandable panel ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

            local Panel = InsertTheme(Create("Frame", Container, {
                Name                 = "CP_" .. CName,
                Size                 = UDim2.new(1, 0, 0, 0),
                BackgroundColor3     = Theme["Color Hub 2"],
                ClipsDescendants     = true,
                BorderSizePixel      = 0,
            }), "Frame")
            Make("Corner",   Panel)
            Make("Stroke",   Panel)
            Make("Gradient", Panel, { Rotation = 45 })

            -- ‚ĒÄ‚ĒÄ SV square ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
            --  Three layers: hue background ‚Üí white-left gradient ‚Üí black-top gradient

            local SVOuter = Create("Frame", Panel, {
                Size             = UDim2.new(0, SV_SZ, 0, SV_SZ),
                Position         = UDim2.fromOffset(MARGIN, MARGIN),
                BackgroundColor3 = Color3.fromHSV(curH, 1, 1),
                BorderSizePixel  = 0,
                ClipsDescendants = true,
            })
            Make("Corner", SVOuter, UDim.new(0, 4))

            -- White saturation overlay
            local WhiteLayer = Create("Frame", SVOuter, {
                Size             = UDim2.fromScale(1, 1),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel  = 0,
            })
            Create("UIGradient", WhiteLayer, {
                Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 0),
                    NumberSequenceKeypoint.new(1, 1),
                }),
                Rotation = 0,
            })

            -- Black value overlay
            local BlackLayer = Create("Frame", SVOuter, {
                Size             = UDim2.fromScale(1, 1),
                BackgroundColor3 = Color3.new(0, 0, 0),
                BorderSizePixel  = 0,
            })
            Create("UIGradient", BlackLayer, {
                Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 1),
                    NumberSequenceKeypoint.new(1, 0),
                }),
                Rotation = 90,
            })

            -- Draggable cursor circle
            local SVCursor = Create("Frame", SVOuter, {
                Size             = UDim2.new(0, 9, 0, 9),
                AnchorPoint      = Vector2.new(0.5, 0.5),
                Position         = UDim2.new(curS, 0, 1 - curV, 0),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel  = 0,
                ZIndex           = 5,
            })
            Make("Corner", SVCursor, UDim.new(0.5, 0))
            Make("Stroke",  SVCursor)

            -- ‚ĒÄ‚ĒÄ Hue bar ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

            local HueBar = Create("Frame", Panel, {
                Size             = UDim2.new(0, HUE_W, 0, SV_SZ),
                Position         = UDim2.fromOffset(MARGIN + SV_SZ + 6, MARGIN),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel  = 0,
                ClipsDescendants = true,
            })
            Make("Corner", HueBar, UDim.new(0, 4))

            local hueKpts = {}
            for i = 0, 6 do
                hueKpts[i + 1] = ColorSequenceKeypoint.new(i / 6, Color3.fromHSV(i / 6, 1, 1))
            end
            Create("UIGradient", HueBar, {
                Color    = ColorSequence.new(hueKpts),
                Rotation = 90,
            })

            local HueLine = Create("Frame", HueBar, {
                Size             = UDim2.new(1, 0, 0, 2),
                Position         = UDim2.new(0, 0, curH, 0),
                AnchorPoint      = Vector2.new(0, 0.5),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel  = 0,
                ZIndex           = 5,
            })
            Make("Stroke", HueLine)

            -- ‚ĒÄ‚ĒÄ Info column ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

            local PreviewBig = Create("Frame", Panel, {
                Size             = UDim2.new(0, 44, 0, 22),
                Position         = UDim2.fromOffset(INFO_X, MARGIN),
                BackgroundColor3 = currentColor,
                BorderSizePixel  = 0,
            })
            Make("Corner", PreviewBig, UDim.new(0, 4))
            Make("Stroke",  PreviewBig)

            local HexLabel = InsertTheme(Create("TextLabel", Panel, {
                Size                 = UDim2.new(0, 60, 0, 14),
                Position             = UDim2.fromOffset(INFO_X, MARGIN + 28),
                BackgroundTransparency = 1,
                Font                 = Enum.Font.GothamBold,
                TextSize             = 9,
                TextXAlignment       = "Left",
                TextColor3           = Theme["Color Text"],
                Text                 = "#FFFFFF",
            }), "Text")

            local RLabel = InsertTheme(Create("TextLabel", Panel, {
                Size                 = UDim2.new(0, 60, 0, 12),
                Position             = UDim2.fromOffset(INFO_X, MARGIN + 48),
                BackgroundTransparency = 1,
                Font                 = Enum.Font.Gotham,
                TextSize             = 8,
                TextXAlignment       = "Left",
                TextColor3           = Theme["Color Dark Text"],
                Text                 = "R 255",
            }), "DarkText")
            local GLabel = InsertTheme(Create("TextLabel", Panel, {
                Size                 = UDim2.new(0, 60, 0, 12),
                Position             = UDim2.fromOffset(INFO_X, MARGIN + 62),
                BackgroundTransparency = 1,
                Font                 = Enum.Font.Gotham,
                TextSize             = 8,
                TextXAlignment       = "Left",
                TextColor3           = Theme["Color Dark Text"],
                Text                 = "G 255",
            }), "DarkText")
            local BLabel = InsertTheme(Create("TextLabel", Panel, {
                Size                 = UDim2.new(0, 60, 0, 12),
                Position             = UDim2.fromOffset(INFO_X, MARGIN + 76),
                BackgroundTransparency = 1,
                Font                 = Enum.Font.Gotham,
                TextSize             = 8,
                TextXAlignment       = "Left",
                TextColor3           = Theme["Color Dark Text"],
                Text                 = "B 255",
            }), "DarkText")

            -- ‚ĒÄ‚ĒÄ Core update function ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

            local function applyColor(h, s, v)
                curH, curS, curV = h, s, v
                currentColor = Color3.fromHSV(h, s, v)

                local r = math.floor(currentColor.R * 255 + 0.5)
                local g = math.floor(currentColor.G * 255 + 0.5)
                local b = math.floor(currentColor.B * 255 + 0.5)

                SVOuter.BackgroundColor3    = Color3.fromHSV(h, 1, 1)
                SVCursor.Position           = UDim2.new(s, 0, 1 - v, 0)
                HueLine.Position            = UDim2.new(0, 0, h, 0)
                Swatch.BackgroundColor3     = currentColor
                PreviewBig.BackgroundColor3 = currentColor
                HexLabel.Text = string.format("#%02X%02X%02X", r, g, b)
                RLabel.Text   = "R " .. r
                GLabel.Text   = "G " .. g
                BLabel.Text   = "B " .. b

                SetFlag(Flag, { r = currentColor.R, g = currentColor.G, b = currentColor.B })
                Funcs:FireCallback(Callback, currentColor)
            end

            -- Initialise
            applyColor(curH, curS, curV)

            -- ‚ĒÄ‚ĒÄ SV drag ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

            local svDown = false

            local function updateSV()
                local abs   = SVOuter.AbsolutePosition
                local sz    = SVOuter.AbsoluteSize
                local mouse = UserInputService:GetMouseLocation()
                local s2 = math.clamp((mouse.X - abs.X) / sz.X, 0, 1)
                local v2 = math.clamp(1 - (mouse.Y - abs.Y) / sz.Y, 0, 1)
                applyColor(curH, s2, v2)
            end

            SVOuter.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    svDown = true
                    updateSV()
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    svDown = false
                end
            end)
            RunService.Heartbeat:Connect(function()
                if svDown then updateSV() end
            end)

            -- ‚ĒÄ‚ĒÄ Hue drag ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

            local hueDown = false

            local function updateHue()
                local abs   = HueBar.AbsolutePosition
                local sz    = HueBar.AbsoluteSize
                local mouse = UserInputService:GetMouseLocation()
                local h2    = math.clamp((mouse.Y - abs.Y) / sz.Y, 0, 1)
                applyColor(h2, curS, curV)
            end

            HueBar.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    hueDown = true
                    updateHue()
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    hueDown = false
                end
            end)
            RunService.Heartbeat:Connect(function()
                if hueDown then updateHue() end
            end)

            -- ‚ĒÄ‚ĒÄ Toggle open / close ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

            local open     = false
            local waitPick = false

            local function togglePicker()
                if waitPick then return end
                waitPick = true
                open = not open
                if open then
                    CreateTween({ Panel,  "Size",     UDim2.new(1, 0, 0, PANEL_H), 0.25 })
                    CreateTween({ Arrow, "Rotation", 180,                           0.2  })
                else
                    CreateTween({ Panel,  "Size",     UDim2.new(1, 0, 0, 0),        0.25 })
                    CreateTween({ Arrow, "Rotation", 0,                             0.2  })
                end
                waitPick = false
            end

            Button.Activated:Connect(togglePicker)

            -- ‚ĒÄ‚ĒÄ Public API ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

            local ColorPicker = {}

            function ColorPicker:Set(NewColor)
                if typeof(NewColor) == "Color3" then
                    local h2, s2, v2 = Color3.toHSV(NewColor)
                    applyColor(h2, s2, v2)
                end
            end

            function ColorPicker:GetColor()
                return currentColor
            end

            function ColorPicker:Callback(...)
                Funcs:InsertCallback(Callback, ...)
                Funcs:FireCallback(Callback, currentColor)
            end

            function ColorPicker:Visible(Bool)
                Funcs:ToggleVisible(Button, Bool)
                if open then Funcs:ToggleVisible(Panel, Bool) end
            end

            function ColorPicker:Destroy()
                Button:Destroy()
                Panel:Destroy()
            end

            return ColorPicker
        end

        -- ‚ĒÄ‚ĒÄ AddDiscordInvite ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        function Tab:AddDiscordInvite(Configs)
            local DTitle = Configs[1] or Configs.Name  or Configs.Title or "Discord"
            local DDesc  = Configs.Desc or Configs.Description or ""
            local Logo   = Configs[2] or Configs.Logo   or ""
            local Invite = Configs[3] or Configs.Invite or ""
            local InviteHolder = Create("Frame", Container, {
                Size                 = UDim2.new(1, 0, 0, 80),
                Name                 = "Option",
                BackgroundTransparency = 1,
            })
            Create("TextLabel", InviteHolder, {
                Size                 = UDim2.new(1, 0, 0, 15),
                Position             = UDim2.new(0, 5),
                TextColor3           = Color3.fromRGB(40, 150, 255),
                Font                 = Enum.Font.GothamBold,
                TextXAlignment       = "Left",
                BackgroundTransparency = 1,
                TextSize             = 10,
                Text                 = Invite,
            })
            local FrameHolder = InsertTheme(Create("Frame", InviteHolder, {
                Size                 = UDim2.new(1, 0, 0, 65),
                AnchorPoint          = Vector2.new(0, 1),
                Position             = UDim2.new(0, 0, 1),
                BackgroundColor3     = Theme["Color Hub 2"],
            }), "Frame")
            Make("Corner", FrameHolder)
            local ImageLabel = Create("ImageLabel", FrameHolder, {
                Size                 = UDim2.new(0, 30, 0, 30),
                Position             = UDim2.new(0, 7, 0, 7),
                Image                = Logo,
                BackgroundTransparency = 1,
            })
            Make("Corner", ImageLabel, UDim.new(0, 4))
            Make("Stroke",  ImageLabel)
            InsertTheme(Create("TextLabel", FrameHolder, {
                Size                 = UDim2.new(1, -52, 0, 15),
                Position             = UDim2.new(0, 44, 0, 7),
                Font                 = Enum.Font.GothamBold,
                TextColor3           = Theme["Color Text"],
                TextXAlignment       = "Left",
                BackgroundTransparency = 1,
                TextSize             = 10,
                Text                 = DTitle,
            }), "Text")
            InsertTheme(Create("TextLabel", FrameHolder, {
                Size                 = UDim2.new(1, -52, 0, 0),
                Position             = UDim2.new(0, 44, 0, 22),
                AutomaticSize        = "Y",
                Font                 = Enum.Font.Gotham,
                TextColor3           = Theme["Color Dark Text"],
                TextXAlignment       = "Left",
                BackgroundTransparency = 1,
                TextSize             = 8,
                TextWrapped          = true,
                Text                 = DDesc,
            }), "DarkText")
            local JoinButton = Create("TextButton", FrameHolder, {
                Size             = UDim2.new(1, -14, 0, 16),
                AnchorPoint      = Vector2.new(0.5, 1),
                Position         = UDim2.new(0.5, 0, 1, -7),
                Text             = "Join",
                Font             = Enum.Font.GothamBold,
                TextSize         = 12,
                TextColor3       = Color3.fromRGB(220, 220, 220),
                BackgroundColor3 = Color3.fromRGB(50, 150, 50),
            })
            Make("Corner", JoinButton, UDim.new(0, 5))
            local ClickDelay
            JoinButton.Activated:Connect(function()
                if rawget(_G, "setclipboard") then pcall(_G.setclipboard, Invite) end
                if ClickDelay then return end
                ClickDelay = true
                SetProps(JoinButton, {
                    Text             = "Copied!",
                    BackgroundColor3 = Color3.fromRGB(100, 100, 100),
                    TextColor3       = Color3.fromRGB(150, 150, 150),
                })
                task.wait(3)
                SetProps(JoinButton, {
                    Text             = "Join",
                    BackgroundColor3 = Color3.fromRGB(50, 150, 50),
                    TextColor3       = Color3.fromRGB(220, 220, 220),
                })
                ClickDelay = false
            end)
            local DiscordInvite = {}
            function DiscordInvite:Destroy()    InviteHolder:Destroy()               end
            function DiscordInvite:Visible(...) Funcs:ToggleVisible(InviteHolder,...) end
            return DiscordInvite
        end

        return Tab
    end  -- MakeTab

    CloseButton.Activated:Connect(function()    Window:CloseBtn()    end)
    MinimizeButton.Activated:Connect(function() Window:MinimizeBtn() end)
    return Window
end  -- MakeWindow

return redzlib
