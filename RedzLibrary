                Position         = UDim2.new(0, 0, 0.5),
                AnchorPoint      = Vector2.new(0, 0.5),
                BackgroundColor3 = Theme["Color Theme"],
            }), "Theme")
            Make("Corner", Toggle, UDim.new(0.5, 0))
            local WaitToggle
            local function SetToggleVal(Val)
                if WaitToggle then return end
                WaitToggle, Default = true, Val
                SetFlag(Flag, Default)
                Funcs:FireCallback(Callback, Default)
                if Default then
                    CreateTween({ Toggle, "Position",               UDim2.new(1,0,0.5),  0.25 })
                    CreateTween({ Toggle, "BackgroundTransparency", 0,                   0.25 })
                    CreateTween({ Toggle, "AnchorPoint",            Vector2.new(1,0.5),  0.25 })
                else
                    CreateTween({ Toggle, "Position",               UDim2.new(0,0,0.5),  0.25 })
                    CreateTween({ Toggle, "BackgroundTransparency", 0.8,                 0.25 })
                    CreateTween({ Toggle, "AnchorPoint",            Vector2.new(0,0.5),  0.25 })
                end
                WaitToggle = false
            end
            task.spawn(SetToggleVal, Default)
            Button.Activated:Connect(function() SetToggleVal(not Default) end)
            local ToggleObj = {}
            function ToggleObj:Visible(...)  Funcs:ToggleVisible(Button, ...) end
            function ToggleObj:Destroy()     Button:Destroy()                 end
            function ToggleObj:Callback(...) Funcs:InsertCallback(Callback, ...) end
            function ToggleObj:Set(Val1, Val2)
                if type(Val1)=="string" and type(Val2)=="string" then LabelFunc:SetTitle(Val1); LabelFunc:SetDesc(Val2)
                elseif type(Val1)=="string"   then LabelFunc:SetTitle(Val1)
                elseif type(Val1)=="boolean"  then
                    if WaitToggle and Val2 then repeat task.wait() until not WaitToggle end
                    task.spawn(SetToggleVal, Val1)
                elseif type(Val1)=="function" then Callback = { Val1 } end
            end
            return ToggleObj
        end

        -- ‚ĒÄ‚ĒÄ AddDropdown ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        function Tab:AddDropdown(Configs)
            local DName        = Configs[1] or Configs.Name  or Configs.Title or "Dropdown"
            local DDesc        = Configs.Desc or Configs.Description or ""
            local DOptions     = Configs[2] or Configs.Options  or {}
            local OpDefault    = Configs[3] or Configs.Default  or {}
            local Flag         = Configs[5] or Configs.Flag     or false
            local DMultiSelect = Configs.MultiSelect            or false
            local Callback     = Funcs:GetCallback(Configs, 4)
            local Button, LabelFunc = ButtonFrame(Container, DName, DDesc, UDim2.new(1, -180))
            local SelectedFrame = InsertTheme(Create("Frame", Button, {
                Size             = UDim2.new(0, 150, 0, 18),
                Position         = UDim2.new(1, -10, 0.5),
                AnchorPoint      = Vector2.new(1, 0.5),
                BackgroundColor3 = Theme["Color Stroke"],
            }), "Stroke")
            Make("Corner", SelectedFrame, UDim.new(0, 4))
            local ActiveLabel = InsertTheme(Create("TextLabel", SelectedFrame, {
                Size                 = UDim2.new(0.85, 0, 0.85, 0),
                AnchorPoint          = Vector2.new(0.5, 0.5),
                Position             = UDim2.new(0.5, 0, 0.5, 0),
                BackgroundTransparency = 1,
                Font                 = Enum.Font.GothamBold,
                TextScaled           = true,
                TextColor3           = Theme["Color Text"],
                Text                 = "...",
            }), "Text")
            local Arrow = Create("ImageLabel", SelectedFrame, {
                Size                 = UDim2.new(0, 15, 0, 15),
                Position             = UDim2.new(0, -5, 0.5),
                AnchorPoint          = Vector2.new(1, 0.5),
                Image                = "rbxassetid://10709791523",
                BackgroundTransparency = 1,
            })
            local NoClickFrame = Create("TextButton", DropdownHolder, {
                Name                 = "AntiClick",
                Size                 = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Visible              = false,
                Text                 = "",
            })
            local DropFrame = Create("Frame", NoClickFrame, {
                Size                 = UDim2.fromOffset(152, 0),
                BackgroundTransparency = 0.1,
                BackgroundColor3     = Color3.fromRGB(255, 255, 255),
                AnchorPoint          = Vector2.new(0, 1),
                Name                 = "DropdownFrame",
                ClipsDescendants     = true,
                Active               = true,
            })
            Make("Corner",   DropFrame)
            Make("Stroke",   DropFrame)
            Make("Gradient", DropFrame, { Rotation = 60 })
            local ScrollFrame = InsertTheme(Create("ScrollingFrame", DropFrame, {
                ScrollBarImageColor3 = Theme["Color Theme"],
                Size                 = UDim2.new(1, 0, 1, 0),
                ScrollBarThickness   = 1.5,
                BackgroundTransparency = 1,
                BorderSizePixel      = 0,
                CanvasSize           = UDim2.new(),
                ScrollingDirection   = "Y",
                AutomaticCanvasSize  = "Y",
                Active               = true,
            }, {
                Create("UIPadding", {
                    PaddingLeft   = UDim.new(0, 8),
                    PaddingRight  = UDim.new(0, 8),
                    PaddingTop    = UDim.new(0, 5),
                    PaddingBottom = UDim.new(0, 5),
                }),
                Create("UIListLayout", { Padding = UDim.new(0, 4) }),
            }), "ScrollBar")
            local ScrollSize, WaitDrop = 5
            local function CloseDropdown()
                WaitDrop = true
                CreateTween({ Arrow,     "Rotation",    0,                           0.2 })
                CreateTween({ DropFrame, "Size",        UDim2.fromOffset(152, 0),    0.2, true })
                CreateTween({ Arrow,     "ImageColor3", Color3.fromRGB(255,255,255), 0.2 })
                Arrow.Image          = "rbxassetid://10709791523"
                NoClickFrame.Visible = false
                WaitDrop = false
            end
            local function GetDropSize() return UDim2.fromOffset(152, ScrollSize) end
            local function CalculateSize()
                local count = 0
                for _, child in ipairs(ScrollFrame:GetChildren()) do
                    if child:IsA("Frame") or child:IsA("TextButton") then count += 1 end
                end
                ScrollSize = (math.clamp(count, 0, 10) * 25) + 10
                if NoClickFrame.Visible then
                    CreateTween({ DropFrame, "Size", GetDropSize(), 0.2, true })
                end
            end
            local function ToggleDropdown()
                if WaitDrop then return end
                WaitDrop = true
                if NoClickFrame.Visible then
                    Arrow.Image = "rbxassetid://10709791523"
                    CreateTween({ Arrow,     "ImageColor3", Color3.fromRGB(255,255,255), 0.2 })
                    CreateTween({ DropFrame, "Size",        UDim2.fromOffset(152, 0),    0.2, true })
                    NoClickFrame.Visible = false
                else
                    NoClickFrame.Visible = true
                    Arrow.Image = "rbxassetid://10709790948"
                    CreateTween({ Arrow,     "ImageColor3", Theme["Color Theme"], 0.2 })
                    CreateTween({ DropFrame, "Size",        GetDropSize(),        0.2, true })
                end
                WaitDrop = false
            end
            local function CalculatePos()
                local FramePos   = SelectedFrame.AbsolutePosition
                local ScreenSize = ScreenGui.AbsoluteSize
                local clampX = math.clamp(FramePos.X / UIScale, 0, ScreenSize.X / UIScale - 152)
                local clampY = math.clamp(FramePos.Y / UIScale, 0, ScreenSize.Y / UIScale)
                local anchor = FramePos.Y > ScreenSize.Y / 1.4 and 1 or ScrollSize > 80 and 0.5 or 0
                DropFrame.AnchorPoint = Vector2.new(0, anchor)
                CreateTween({ DropFrame, "Position", UDim2.fromOffset(clampX, clampY), 0.1 })
            end
            local DropSelected, Options, AddOption, RemoveOption, AddNewOptions
            local MultiSelect = DMultiSelect
            do
                Options = {}
                local defaultRaw = type(OpDefault) ~= "table" and { OpDefault } or OpDefault
                DropSelected = MultiSelect and {} or (CheckFlag(Flag) and GetFlag(Flag) or defaultRaw[1])
                if MultiSelect then
                    for idx, val in pairs(CheckFlag(Flag) and GetFlag(Flag) or defaultRaw) do
                        local name = type(idx) == "string" and idx or tostring(val)
                        DropSelected[name] = true
                    end
                end
                local function FireCallback()
                    SetFlag(Flag, MultiSelect and DropSelected or tostring(DropSelected))
                    Funcs:FireCallback(Callback, DropSelected)
                end
                local function UpdateLabel()
                    if MultiSelect then
                        local parts = {}
                        for k, v in pairs(DropSelected) do if v then table.insert(parts, k) end end
                        ActiveLabel.Text = #parts > 0 and table.concat(parts, ", ") or "..."
                    else
                        ActiveLabel.Text = tostring(DropSelected or "...")
                    end
                end
                local function UpdateSelected()
                    for _, v in pairs(Options) do
                        local nodes  = v.nodes
                        local active = MultiSelect and (DropSelected[v.Name] == true) or (v.Value == DropSelected)
                        CreateTween({ nodes[2], "BackgroundTransparency", active and 0 or (MultiSelect and 0.8 or 1), 0.35 })
                        CreateTween({ nodes[2], "Size", active and UDim2.fromOffset(4,12) or UDim2.fromOffset(4,4), 0.35 })
                        CreateTween({ nodes[3], "TextTransparency", active and 0 or 0.4, 0.35 })
                    end
                    UpdateLabel()
                end
                local function SelectOption(opt)
                    if MultiSelect then
                        opt.Stats = not opt.Stats
                        DropSelected[opt.Name] = opt.Stats
                    else
                        DropSelected = opt.Value
                    end
                    FireCallback(); UpdateSelected()
                end
                AddOption = function(idx, val)
                    local name = tostring(type(idx) == "string" and idx or val)
                    if Options[name] then return end
                    Options[name] = { index = idx, Value = val or idx, Name = name, Stats = false }
                    if MultiSelect then
                        local s = DropSelected[name]
                        DropSelected[name] = s or false
                        Options[name].Stats = s or false
                    end
                    local Btn = Make("Button", ScrollFrame, {
                        Name = "DropBtn_" .. name,
                        Size = UDim2.new(1, 0, 0, 21),
                    })
                    Make("Corner", Btn, UDim.new(0, 4))
                    local Indicator = InsertTheme(Create("Frame", Btn, {
                        Position         = UDim2.new(0, 1, 0.5),
                        Size             = UDim2.fromOffset(4, 4),
                        BackgroundColor3 = Theme["Color Theme"],
                        BackgroundTransparency = 1,
                        AnchorPoint      = Vector2.new(0, 0.5),
                    }), "Theme")
                    Make("Corner", Indicator, UDim.new(0.5, 0))
                    local NameLabel = InsertTheme(Create("TextLabel", Btn, {
                        Size                 = UDim2.new(1, 0, 1),
                        Position             = UDim2.new(0, 10),
                        Text                 = name,
                        TextColor3           = Theme["Color Text"],
                        Font                 = Enum.Font.GothamBold,
                        TextXAlignment       = "Left",
                        BackgroundTransparency = 1,
                        TextTransparency     = 0.4,
                    }), "Text")
                    Btn.Activated:Connect(function() SelectOption(Options[name]) end)
                    Options[name].nodes = { Btn, Indicator, NameLabel }
                    Connection:FireConnection("OptionAdded", name)
                end
                RemoveOption = function(name)
                    name = tostring(name)
                    local opt = Options[name]
                    if not opt then return end
                    if MultiSelect then DropSelected[name] = nil else DropSelected = nil end
                    pcall(opt.nodes[1].Destroy, opt.nodes[1])
                    Options[name] = nil
                end
                AddNewOptions = function(List, Clear)
                    if Clear then
                        for name in pairs(Options) do RemoveOption(name) end
                    end
                    for idx, val in pairs(List) do AddOption(idx, val) end
                    FireCallback(); UpdateSelected()
                end
                for idx, val in pairs(DOptions) do AddOption(idx, val) end
                FireCallback(); UpdateSelected()
            end
            Button.Activated:Connect(ToggleDropdown)
            NoClickFrame.MouseButton1Down:Connect(CloseDropdown)
            NoClickFrame.MouseButton1Click:Connect(CloseDropdown)
            MainFrame:GetPropertyChangedSignal("Visible"):Connect(CloseDropdown)
            SelectedFrame:GetPropertyChangedSignal("AbsolutePosition"):Connect(CalculatePos)
            Button.Activated:Connect(CalculateSize)
            ScrollFrame.ChildAdded:Connect(CalculateSize)
            ScrollFrame.ChildRemoved:Connect(CalculateSize)
            CalculatePos(); CalculateSize()
            local Dropdown = {}
            function Dropdown:Visible(...)  Funcs:ToggleVisible(Button, ...)                                         end
            function Dropdown:Destroy()     Button:Destroy()                                                         end
            function Dropdown:Callback(...) Funcs:InsertCallback(Callback,...); Funcs:FireCallback(Callback, DropSelected) end
            function Dropdown:GetSelected() return DropSelected                                                      end
            function Dropdown:Refresh(List) if type(List)=="table" then AddNewOptions(List, true) end                end
            function Dropdown:Add(...)
                local args = { ... }
                if type(args[1]) == "table" then for _, name in ipairs(args[1]) do AddOption(name) end
                else for _, name in ipairs(args) do AddOption(name) end end
            end
            function Dropdown:Remove(OptionName) RemoveOption(tostring(OptionName)) end
            function Dropdown:Set(Val1)
                if type(Val1) == "table" then
                    if MultiSelect then
                        for k in pairs(DropSelected) do DropSelected[k] = false end
                        for _, name in ipairs(Val1) do
                            if Options[tostring(name)] then
                                DropSelected[tostring(name)] = true
                                Options[tostring(name)].Stats = true
                            end
                        end
                    else
                        DropSelected = Val1[1] or nil
                    end
                    SetFlag(Flag, MultiSelect and DropSelected or tostring(DropSelected))
                    Funcs:FireCallback(Callback, DropSelected)
                    for _, v in pairs(Options) do
                        local active = MultiSelect and (DropSelected[v.Name] == true) or (v.Value == DropSelected)
                        pcall(function()
                            CreateTween({ v.nodes[2], "BackgroundTransparency", active and 0 or (MultiSelect and 0.8 or 1), 0.2 })
                            CreateTween({ v.nodes[2], "Size", active and UDim2.fromOffset(4,12) or UDim2.fromOffset(4,4), 0.2 })
                            CreateTween({ v.nodes[3], "TextTransparency", active and 0 or 0.4, 0.2 })
                        end)
                    end
                    if MultiSelect then
                        local parts = {}
                        for k, v in pairs(DropSelected) do if v then table.insert(parts, k) end end
                        ActiveLabel.Text = #parts > 0 and table.concat(parts, ", ") or "..."
                    else
                        ActiveLabel.Text = tostring(DropSelected or "...")
                    end
                elseif type(Val1) == "function" then
                    Callback = { Val1 }
                end
            end
            return Dropdown
        end

        -- ‚ĒÄ‚ĒÄ AddSlider ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        function Tab:AddSlider(Configs)
            local SName    = Configs[1] or Configs.Name  or Configs.Title or "Slider"
            local SDesc    = Configs.Desc or Configs.Description or ""
            local Min      = Configs[2] or Configs.Min      or Configs.MinValue or 0
            local Max      = Configs[3] or Configs.Max      or Configs.MaxValue or 100
            local Increase = Configs[4] or Configs.Increase or 1
            local Default  = Configs[5] or Configs.Default  or Min
            local Callback = Funcs:GetCallback(Configs, 6)
            local Flag     = Configs[7] or Configs.Flag or false
            if CheckFlag(Flag) then Default = GetFlag(Flag) end
            local MinN = Min / Increase
            local MaxN = Max / Increase
            local Button, LabelFunc = ButtonFrame(Container, SName, SDesc, UDim2.new(1, -180))
            local SliderHolder = Create("TextButton", Button, {
                Size            = UDim2.new(0.45, 0, 1),
                Position        = UDim2.new(1),
                AnchorPoint     = Vector2.new(1, 0),
                AutoButtonColor = false,
                Text            = "",
                BackgroundTransparency = 1,
            })
            local SliderBar = InsertTheme(Create("Frame", SliderHolder, {
                BackgroundColor3 = Theme["Color Stroke"],
                Size             = UDim2.new(1, -20, 0, 6),
                Position         = UDim2.new(0.5, 0, 0.5),
                AnchorPoint      = Vector2.new(0.5, 0.5),
            }), "Stroke")
            Make("Corner", SliderBar)
            local Indicator = InsertTheme(Create("Frame", SliderBar, {
                BackgroundColor3 = Theme["Color Theme"],
                Size             = UDim2.fromScale(0, 1),
                BorderSizePixel  = 0,
            }), "Theme")
            Make("Corner", Indicator)
            local SliderIcon = Create("Frame", SliderBar, {
                Size             = UDim2.new(0, 6, 0, 12),
                BackgroundColor3 = Color3.fromRGB(220, 220, 220),
                Position         = UDim2.fromScale(0, 0.5),
                AnchorPoint      = Vector2.new(0.5, 0.5),
                BackgroundTransparency = 0.2,
            })
            Make("Corner", SliderIcon)
            local LabelVal = InsertTheme(Create("TextLabel", SliderHolder, {
                Size                 = UDim2.new(0, 28, 0, 14),
                AnchorPoint          = Vector2.new(1, 0.5),
                Position             = UDim2.new(0, -2, 0.5),
                BackgroundTransparency = 1,
                TextColor3           = Theme["Color Text"],
                Font                 = Enum.Font.GothamBold,
                TextSize             = 9,
                Text                 = tostring(Default),
            }), "Text")
            Create("Frame", SliderBar, { Position = UDim2.new(0,0,0.5,0), Visible = false })
            local currentValue = Default
            local function UpdateDisplay(val)
                currentValue  = val
                LabelVal.Text = tostring(val)
                Funcs:FireCallback(Callback, val)
            end
            local function ControlPos()
                local mouse = Player:GetMouse()
                local rel   = (mouse.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X
                SliderIcon.Position = UDim2.fromScale(math.clamp(rel, 0, 1), 0.5)
            end
            local function UpdateValues()
                local pct = SliderIcon.Position.X.Scale
                Indicator.Size = UDim2.new(pct, 0, 1, 0)
                local raw = math.floor(pct * (MaxN - MinN) + MinN)
                local val = math.floor((raw * Increase) * 100) / 100
                UpdateDisplay(val)
            end
            SliderHolder.MouseButton1Down:Connect(function()
                CreateTween({ SliderIcon, "BackgroundTransparency", 0, 0.15 })
                Container.ScrollingEnabled = false
                while UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                    task.wait(); ControlPos()
                end
                CreateTween({ SliderIcon, "BackgroundTransparency", 0.2, 0.15 })
                Container.ScrollingEnabled = true
                SetFlag(Flag, currentValue)
            end)
            local function SetSlider(newVal)
                if type(newVal) ~= "number" then return end
                newVal = math.clamp(newVal, Min, Max)
                local pct = (newVal - Min) / (Max - Min)
                SetFlag(Flag, newVal)
                CreateTween({ SliderIcon, "Position", UDim2.fromScale(math.clamp(pct,0,1), 0.5), 0.25, true })
            end
            SliderIcon:GetPropertyChangedSignal("Position"):Connect(UpdateValues)
            task.spawn(SetSlider, Default)
            local Slider = {}
            function Slider:Set(NewVal1, NewVal2)
                if type(NewVal1)=="string" and type(NewVal2)=="string" then LabelFunc:SetTitle(NewVal1); LabelFunc:SetDesc(NewVal2)
                elseif type(NewVal1)=="string"   then LabelFunc:SetTitle(NewVal1)
                elseif type(NewVal1)=="function" then Callback = { NewVal1 }
                elseif type(NewVal1)=="number"   then SetSlider(NewVal1) end
            end
            function Slider:GetValue()    return currentValue                                        end
            function Slider:Callback(...) Funcs:InsertCallback(Callback,...); Funcs:FireCallback(Callback, currentValue) end
            function Slider:Visible(...)  Funcs:ToggleVisible(Button, ...)                           end
            function Slider:Destroy()     Button:Destroy()                                           end
            return Slider
        end

