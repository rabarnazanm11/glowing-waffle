            TextXAlignment       = "Left",
            TextWrapped          = true,
            BackgroundTransparency = 1,
            ZIndex               = 11,
        }), "DarkText")
    end
    Card.Parent = NotifHolder
    CreateTween({ Card, "Size", UDim2.new(1, 0, 0, cardH), 0.25 })
    task.delay(NDuration, function()
        CreateTween({ Card, "BackgroundTransparency", 1, 0.3 })
        CreateTween({ Card, "Size", UDim2.new(1, 0, 0, 0), 0.3, true })
        pcall(Card.Destroy, Card)
    end)
end

