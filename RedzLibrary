        AutomaticSize = "Y",
        BackgroundTransparency = 1,
        Size        = HolderSize,
        Position    = UDim2.new(0, 10, 0.5),
        AnchorPoint = Vector2.new(0, 0.5),
    }, {
        Create("UIListLayout", {
            SortOrder         = "LayoutOrder",
