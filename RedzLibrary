local function CheckFlag(Name)
    return type(Name) == "string" and Flags[Name] ~= nil
end
local function GetFlag(Name)
    return type(Name) == "string" and Flags[Name]
end
local function SetFlag(Flag, Value)
    if Flag and (Value ~= Flags[Flag] or type(Value) == "table") then
        Flags[Flag] = Value
        Connection:FireConnection("FlagsChanged", Flag, Value)
    end
end
Flags.GetFlag   = function(self, Name)        return GetFlag(Name)         end
Flags.CheckFlag = function(self, Name)        return CheckFlag(Name)       end
Flags.SetFlag   = function(self, Flag, Value) return SetFlag(Flag, Value)  end

local _flagSaveDb
Connection.FlagsChanged:Connect(function()
    local ScriptFile = Settings.ScriptFile
    if not _flagSaveDb and ScriptFile and rawget(_G, "writefile") then
        _flagSaveDb = true
        task.delay(0.1, function()
            _flagSaveDb = false
            local tbl = {}
            for k, v in pairs(Flags) do
                if type(v) ~= "function" then tbl[k] = v end
            end
            local ok, encoded = pcall(HttpService.JSONEncode, HttpService, tbl)
            if ok then
                local ok2 = pcall(_G.writefile, ScriptFile, encoded)
                if ok2 then
                    Connection:FireConnection("FileSaved", "Script-Flags", ScriptFile, encoded)
                end
            end
        end)
    end
end)

