--==================================================
-- Advanced Anti-AFK System
--==================================================

local AntiAFK = {}

local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local Camera = workspace.CurrentCamera

AntiAFK.Interval = 60
AntiAFK.Enabled = false

local LastActivity = tick()
local ScreenGui, TimerLabel

local function CreateUI()
	ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "AntiAFK_Timer"
	ScreenGui.ResetOnSpawn = false
	ScreenGui.DisplayOrder = 999
	ScreenGui.Parent = PlayerGui

	local Frame = Instance.new("Frame")
	Frame.Size = UDim2.new(0, 120, 0, 24)
	Frame.AnchorPoint = Vector2.new(1, 0)        -- anchor to top-right of itself
	Frame.Position = UDim2.new(1, -10, 0, 10)    -- 10px from right edge, 10px from top
	Frame.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
	Frame.BackgroundTransparency = 0.15
	Frame.BorderSizePixel = 0
	Frame.Parent = ScreenGui

	local Corner = Instance.new("UICorner")
	Corner.CornerRadius = UDim.new(1, 0)
	Corner.Parent = Frame

	local Stroke = Instance.new("UIStroke")
	Stroke.Color = Color3.fromRGB(70, 70, 70)
	Stroke.Thickness = 1
	Stroke.Transparency = 0.4
	Stroke.Parent = Frame

	-- Green dot
	local Dot = Instance.new("Frame")
	Dot.Size = UDim2.new(0, 6, 0, 6)
	Dot.Position = UDim2.new(0, 9, 0.5, -3)
	Dot.BackgroundColor3 = Color3.fromRGB(80, 220, 80)
	Dot.BorderSizePixel = 0
	Dot.Parent = Frame
	Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)

	TimerLabel = Instance.new("TextLabel")
	TimerLabel.Size = UDim2.new(1, -22, 1, 0)
	TimerLabel.Position = UDim2.new(0, 20, 0, 0)
	TimerLabel.BackgroundTransparency = 1
	TimerLabel.TextColor3 = Color3.fromRGB(210, 210, 210)
	TimerLabel.TextSize = 10
	TimerLabel.Font = Enum.Font.GothamBold
	TimerLabel.TextXAlignment = Enum.TextXAlignment.Left
	TimerLabel.Text = "Anti-AFK: --s"
	TimerLabel.Parent = Frame
end

local function RemoveUI()
	if ScreenGui then
		ScreenGui:Destroy()
		ScreenGui = nil
		TimerLabel = nil
	end
end

local function RegisterActivity()
	LastActivity = tick()
end

UserInputService.InputBegan:Connect(RegisterActivity)
UserInputService.InputChanged:Connect(RegisterActivity)

function AntiAFK:Start()
	if self.Enabled then return end
	self.Enabled = true
	CreateUI()

	task.spawn(function()
		while self.Enabled do
			task.wait(0.1)
			local idleTime = tick() - LastActivity
			local remaining = math.max(0, math.floor(self.Interval - idleTime))

			if TimerLabel then
				TimerLabel.Text = "Anti-AFK: " .. remaining .. "s"
			end

			if idleTime >= self.Interval then
				VirtualUser:Button2Down(Vector2.new(), Camera.CFrame)
				task.wait(0.2)
				VirtualUser:Button2Up(Vector2.new(), Camera.CFrame)
				LastActivity = tick()
			end
		end
	end)
end

function AntiAFK:Stop()
	self.Enabled = false
	RemoveUI()
end

return AntiAFK
