-- FIX 1: copyText now returns bool so feedback only fires on success
local function copyText(text)
    if setclipboard then
        local ok = pcall(setclipboard, text)
        if ok then return true end
    end
    if Clipboard and Clipboard.set then
        local ok = pcall(Clipboard.set, text)
        if ok then return true end
    end
    return false
end

-- // Formatters
local function fmtCFrame(cf)
    return string.format(
        "CFrame.new(%.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f)",
        cf.X, cf.Y, cf.Z,
        cf.XVector.X, cf.XVector.Y, cf.XVector.Z,
        cf.YVector.X, cf.YVector.Y, cf.YVector.Z,
        cf.ZVector.X, cf.ZVector.Y, cf.ZVector.Z
    )
end

local function fmtPivot(cf)
    return string.format(
        "%.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f, %.6f",
        cf.X, cf.Y, cf.Z,
        cf.XVector.X, cf.XVector.Y, cf.XVector.Z,
        cf.YVector.X, cf.YVector.Y, cf.YVector.Z,
        cf.ZVector.X, cf.ZVector.Y, cf.ZVector.Z
    )
end

local function fmtVector(cf)
    return string.format("Vector3.new(%.6f, %.6f, %.6f)", cf.X, cf.Y, cf.Z)
end

-- // Drag helper
-- FIX 5: returns both the dist query fn AND a disconnect fn for cleanup
local function MakeDraggable(handle, target)
    local dragging  = false
    local dragStart = nil
    local startPos  = nil
    local dragDist  = 0

    local c1 = handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragDist  = 0
            dragStart = input.Position
            startPos  = target.Position
        end
    end)

    local c2 = handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    local c3 = UserInputService.InputChanged:Connect(function(input)
        if dragging and (
            input.UserInputType == Enum.UserInputType.MouseMovement or
            input.UserInputType == Enum.UserInputType.Touch
        ) then
            local delta = input.Position - dragStart
            dragDist = delta.Magnitude
            target.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    local function getDist()    return dragDist end
    local function disconnect() c1:Disconnect() c2:Disconnect() c3:Disconnect() end

    return getDist, disconnect
end

