-- // Button factory
-- FIX 2: copying flag per button prevents hover/up events from overwriting green feedback
local function NewButton(text, color, order)
    local btn     = Instance.new("TextButton")
    local copying = false  -- lock flag

    btn.Size = UDim2.new(1, 0, 0, 32)
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = C.Text
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.LayoutOrder = order
    btn.Parent = BtnContainer

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    local stroke = Instance.new("UIStroke")
    stroke.Color = color:Lerp(Color3.new(1, 1, 1), 0.2)
    stroke.Thickness = 1
    stroke.Transparency = 0.6
    stroke.Parent = btn

    btn.MouseEnter:Connect(function()
        if copying then return end
        TweenService:Create(btn, TWEEN_SHORT, {BackgroundColor3 = color:Lerp(Color3.new(1,1,1), 0.18)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        if copying then return end
        TweenService:Create(btn, TWEEN_SHORT, {BackgroundColor3 = color}):Play()
    end)
    btn.MouseButton1Down:Connect(function()
        if copying then return end
        TweenService:Create(btn, TweenInfo.new(0.07), {BackgroundColor3 = color:Lerp(Color3.new(0,0,0), 0.18)}):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        if copying then return end
        TweenService:Create(btn, TWEEN_SHORT, {BackgroundColor3 = color}):Play()
    end)

    -- expose lock so click handler can set it
    local function setCopying(state) copying = state end

    return btn, setCopying
end

-- FIX 3: all three buttons use palette colors — no inline Color3.fromRGB duplicates
local CFrameBtn,  setCopyingCFrame  = NewButton("Copy CFrame",     C.Accent, 1)
local PivotBtn,   setCopyingPivot   = NewButton("Copy WorldPivot", C.Red,    2)
local VectorBtn,  setCopyingVector  = NewButton("Copy Vector3",    C.Green,  3)

local BUTTONS = {
    {btn = CFrameBtn,  setCopying = setCopyingCFrame,  color = C.Accent, label = "Copy CFrame",     fn = fmtCFrame},
    {btn = PivotBtn,   setCopying = setCopyingPivot,   color = C.Red,    label = "Copy WorldPivot", fn = fmtPivot},
    {btn = VectorBtn,  setCopying = setCopyingVector,  color = C.Green,  label = "Copy Vector3",    fn = fmtVector},
}

-- // Button wiring
for _, d in ipairs(BUTTONS) do
    d.btn.MouseButton1Click:Connect(function()
        local part = getHRP()
        if not part then return end

        -- FIX 1: only show feedback if copy actually succeeded
        local ok = copyText(d.fn(part.CFrame))
        if not ok then return end

        d.setCopying(true)
        d.btn.Text = "Copied"
        TweenService:Create(d.btn, TWEEN_SHORT, {BackgroundColor3 = C.Green}):Play()

        task.delay(1.4, function()
            if d.btn and d.btn.Parent then
                d.btn.Text = d.label
                TweenService:Create(d.btn, TWEEN_MED, {BackgroundColor3 = d.color}):Play()
                d.setCopying(false)
            end
        end)
    end)
end

