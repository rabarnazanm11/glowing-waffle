ToggleBtn.MouseButton1Click:Connect(function()
    if getToggleDragDist() > 6 then return end

    panelVisible = not panelVisible

    if panelVisible then
        Panel.Visible = true
        Panel.Size = UDim2.new(0, PANEL_W, 0, 0)
        TweenService:Create(Panel, TWEEN_MED, {Size = UDim2.new(0, PANEL_W, 0, PANEL_H)}):Play()
        ToggleBtn.Text = "Hide"
    else
        local t = TweenService:Create(Panel, TWEEN_MED, {Size = UDim2.new(0, PANEL_W, 0, 0)})
        t.Completed:Connect(function()
            Panel.Visible = false
            Panel.Size = UDim2.new(0, PANEL_W, 0, PANEL_H) -- restore for next show
        end)
        t:Play()
        ToggleBtn.Text = "Show"
    end
