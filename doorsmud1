Core.Utils = {
    W2S = function(pos)
        local v,onScreen = workspace.CurrentCamera:WorldToViewportPoint(pos)
        return Vector2.new(v.X,v.Y), onScreen, v.Z
    end,
    getPos = function(inst)
        if not inst then return end
        if inst:IsA("BasePart") then return inst.Position end
        if inst.PrimaryPart then return inst.PrimaryPart.Position end
        local bp = inst:FindFirstChildWhichIsA("BasePart", true)
        return bp and bp.Position
    end,
    getRoomNum = function(inst)
        local p = inst
        while p and p.Parent do
            if p.Parent.Name == "CurrentRooms" then return tonumber(p.Name) end
            p = p.Parent
        end
    end,
    isInESPRange = function(inst)
        local curRoom = game.Players.LocalPlayer:GetAttribute("CurrentRoom")
        if not curRoom then return true end
        local roomNum = Core.Utils.getRoomNum(inst)
        return roomNum and math.abs(roomNum - curRoom) <= 1
    end,
    isDoorLocked = function(room)
        local door = room:FindFirstChild("Door")
        return door and door:FindFirstChild("Lock")
    end,
    makeHighlight = function(inst,color)
        local h = Instance.new("Highlight")
        h.FillColor = color; h.OutlineColor = color
        h.FillTransparency = 0.4; h.OutlineTransparency = 0
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Parent = inst
        return h
    end
}

