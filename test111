task.spawn(function()
    while task.wait() do
        pcall(function()
            local hrp  = GetHRP() if not hrp then return end
            local char = LocalPlayer.Character
            local tool = char and char:FindFirstChildOfClass("Tool")
            local others, basePart = {}, nil

            local function collectFolder(folder)
                for _, mob in pairs(folder:GetChildren()) do
                    local head = mob:FindFirstChild("Head") or mob:FindFirstChild("HumanoidRootPart")
                    local hum  = mob:FindFirstChildOfClass("Humanoid")
                    if head and hum and hum.Health > 0 and mob ~= char then
                        if (hrp.Position - head.Position).Magnitude <= 65 then
                            table.insert(others, {mob, head})
                            if not basePart then basePart = head end
                        end
                    end
                end
            end

            collectFolder(Enemies)
            collectFolder(Characters)
            if #others == 0 then return end

            if tool and tool:FindFirstChild("LeftClickRemote") then
                for _, ed in ipairs(others) do
                    local enemy = ed[1]
                    if enemy:FindFirstChild("HumanoidRootPart") then
                        local dir = (enemy.HumanoidRootPart.Position - hrp.Position).Unit
                        pcall(function() tool.LeftClickRemote:FireServer(dir, 1) end)
                    end
                end
            elseif basePart then
                RegAtk:FireServer(0)
                RegHit:FireServer(basePart, others)
            end
        end)
    end
end)

-- ============================================================
-- AUTO MOB MAGNET  (FIXED)
-- Uses SimulationRadius + ChangeState + Animator removal
-- to properly freeze and snap mobs to the player
-- ============================================================
task.spawn(function()
    while task.wait() do
        pcall(function()
            if not F.AutoMagnet then return end
            local hrp = GetHRP() if not hrp then return end
            pcall(function() sethiddenproperty(LocalPlayer, "SimulationRadius", math.huge) end)
            for _, mob in pairs(Enemies:GetChildren()) do
                local mr = mob:FindFirstChild("HumanoidRootPart")
                local mh = mob:FindFirstChildOfClass("Humanoid")
                if mr and mh and mh.Health > 0 then
                    local dist = (hrp.Position - mr.Position).Magnitude
                    if dist <= 200 and dist > 8 then
                        pcall(function()
                            -- Kill the animator so the mob stops fighting back movement
                            if mh:FindFirstChild("Animator") then
                                mh.Animator:Destroy()
                            end
                            mr.CanCollide    = false
                            mr.Size          = Vector3.new(50, 50, 50)
                            mr.Transparency  = 1
                            mh.WalkSpeed     = 0
                            mh.JumpPower     = 0
                            -- Freeze state then freefall so physics engine
                            -- doesn't fight the CFrame assignment
                            mh:ChangeState(11)
                            mh:ChangeState(14)
                            mr.CFrame = hrp.CFrame * CFrame.new(0, 5, 0)
                        end)
                    end
                end
            end
        end)
    end
end)

