local FarmTab = Window:MakeTab({"Auto Farms"})
FarmTab:AddDropdown({Name="Select Weapon", Options={"Melee","Sword","Gun","Fruit"}, Callback=function(v) SelectWeapon=v end})
FarmTab:AddToggle({Name="Auto Farm Level", Description="Accepts quest for your level then farms mobs", Default=false, Callback=function(v)
    F.AutoFarmLevel = v
    if not v then CommF_:InvokeServer("AbandonQuest") if currentTween then currentTween:Cancel() currentTween=nil end return end
    task.spawn(function()
        while F.AutoFarmLevel do
            pcall(function()
                CheckQ()
                if not NameMon or not CFrameQuest or not CFrameMon then return end
                if QuestVisible() and not string.find(QuestTitle(), NameMon) then CommF_:InvokeServer("AbandonQuest") end
                if not QuestVisible() then
                    CheckQ() AcceptQuest(function() return F.AutoFarmLevel end)
                elseif QuestVisible() then
                    CheckQ()
                    if Enemies:FindFirstChild(NameMon) then
                        for _, mob in pairs(Enemies:GetChildren()) do
                            local r=mob:FindFirstChild("HumanoidRootPart") local h=mob:FindFirstChild("Humanoid")
                            if mob.Name==NameMon and r and h and h.Health>0 and string.find(QuestTitle(),NameMon) then
                                repeat task.wait() EquipWeapon(SelectWeapon) TP(r.CFrame*MethodFarm)
                                until not F.AutoFarmLevel or h.Health<=0 or not mob.Parent or not QuestVisible()
                            end
                        end
                    else
                        local rs=ReplicatedStorage:FindFirstChild(NameMon)
                        if rs and rs:FindFirstChild("HumanoidRootPart") then TP(rs.HumanoidRootPart.CFrame*CFrame.new(0,40,0)) else TP(CFrameMon) end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end})

FarmTab:AddToggle({Name="Nearest Mob Farm", Description="Farms the closest enemy regardless of quest", Default=false, Callback=function(v)
    F.NearestFarm = v
    if v then task.spawn(function()
        while F.NearestFarm do
            pcall(function()
                local hrp=GetHRP() if not hrp then return end
                local best, bd = nil, math.huge
                for _, mob in pairs(Enemies:GetChildren()) do
                    local r=mob:FindFirstChild("HumanoidRootPart") local h=mob:FindFirstChildOfClass("Humanoid")
                    if r and h and h.Health>0 then
                        local d=(hrp.Position-r.Position).Magnitude
                        if d<bd then best,bd=mob,d end
                    end
                end
                if best then
                    EquipWeapon(SelectWeapon)
                    repeat task.wait() TP(best.HumanoidRootPart.CFrame*MethodFarm)
                    until not F.NearestFarm or not best.Parent or best.Humanoid.Health<=0
                end
            end)
            task.wait(0.1)
        end
    end) end
end})

