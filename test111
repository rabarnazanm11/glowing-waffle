-- ESP LOOP
-- ============================================================
local ESPId = tostring(math.random(1, 1000000))
local function SetBB(parent, tag, color, text)
    local ex = parent:FindFirstChild(tag)
    if ex then pcall(function() ex.TextLabel.Text = text end) return end
    local bb  = Instance.new("BillboardGui", parent)
    bb.Name        = tag
    bb.ExtentsOffset = Vector3.new(0, 1, 0)
    bb.Size        = UDim2.new(1, 200, 1, 30)
    bb.Adornee     = parent
    bb.AlwaysOnTop = true
    local lbl = Instance.new("TextLabel", bb)
    lbl.Font               = Enum.Font.Code
    lbl.TextSize           = 14
    lbl.TextWrapped        = true
    lbl.Size               = UDim2.new(1, 0, 1, 0)
    lbl.TextYAlignment     = Enum.TextYAlignment.Top
    lbl.BackgroundTransparency = 1
    lbl.TextStrokeTransparency = 0.5
    lbl.TextColor3         = color
    lbl.Text               = text
end
local function DelBB(parent, tag)
    local b = parent:FindFirstChild(tag) if b then b:Destroy() end
end

task.spawn(function()
    while task.wait(2) do
        pcall(function()
            local myCh   = LocalPlayer.Character
            local myHead = myCh and myCh:FindFirstChild("Head")
            if not myHead then return end

            -- Player ESP
            for _, plr in pairs(Players:GetChildren()) do
                pcall(function()
                    if plr == LocalPlayer then return end
                    local ph = plr.Character and plr.Character:FindFirstChild("Head")
                    if not ph then return end
                    local tag = "NameEsp" .. ESPId
                    if F.ESPPlayer then
                        local dist = Round((myHead.Position - ph.Position).Magnitude / 3)
                        local hum  = plr.Character:FindFirstChildOfClass("Humanoid")
                        local hpTx = hum and Round(hum.Health * 100 / hum.MaxHealth) .. "%" or "?"
                        local col  = plr.Team == LocalPlayer.Team and Color3.new(0,1,0) or Color3.new(1,0,0)
                        SetBB(ph, tag, col, plr.Name .. " | " .. dist .. " M\nHealth: " .. hpTx)
                    else DelBB(ph, tag) end
                end)
            end

            -- Island ESP
            pcall(function()
                for _, loc in pairs(workspace._WorldOrigin.Locations:GetChildren()) do
                    pcall(function()
                        if loc.Name == "Sea" then return end
                        if F.ESPIsland then
                            local dist = Round((myHead.Position - loc.Position).Magnitude / 3)
                            SetBB(loc, "NameEsp", Color3.fromRGB(80, 245, 245), loc.Name .. "\n" .. dist .. " M")
                        else DelBB(loc, "NameEsp") end
                    end)
                end
            end)

            -- Devil Fruit ESP
            for _, obj in pairs(workspace:GetChildren()) do
                pcall(function()
                    if string.find(obj.Name, "Fruit") and obj:FindFirstChild("Handle") then
                        local tag  = "NameEsp" .. ESPId
                        local dist = Round((myHead.Position - obj.Handle.Position).Magnitude / 3)
                        if F.ESPFruit then SetBB(obj.Handle, tag, Color3.fromRGB(255, 50, 50), obj.Name .. "\n" .. dist .. " M")
                        else DelBB(obj.Handle, tag) end
                    end
                end)
            end

            -- Chest ESP (CollectionService)
            for _, chest in pairs(CollectionSvc:GetTagged("_ChestTagged")) do
                pcall(function()
                    if chest:GetAttribute("IsDisabled") then return end
                    local adornee = chest:IsA("Model")
                        and (chest.PrimaryPart or chest:FindFirstChildWhichIsA("BasePart"))
                        or chest
                    if not adornee then return end
                    local dist = Round((myHead.Position - adornee.Position).Magnitude / 3)
                    local tag  = "ChestEsp" .. ESPId
                    if F.ESPChest then SetBB(adornee, tag, Color3.fromRGB(255, 215, 0), "Chest\n" .. dist .. " M")
                    else DelBB(adornee, tag) end
                end)
            end
            -- Fallback by name
            for _, obj in pairs(workspace:GetChildren()) do
                pcall(function()
                    if string.find(obj.Name, "Chest") then
                        local tag  = "NameEsp" .. ESPId
                        local dist = Round((myHead.Position - obj.Position).Magnitude / 3)
                        if F.ESPChest then SetBB(obj, tag, Color3.fromRGB(0, 255, 220), obj.Name .. "\n" .. dist .. " M")
                        else DelBB(obj, tag) end
                    end
                end)
            end

            -- Flower ESP
            for _, obj in pairs(workspace:GetChildren()) do
                pcall(function()
                    if obj.Name == "Flower1" or obj.Name == "Flower2" then
                        local tag   = "NameEsp" .. ESPId
                        local dist  = Round((myHead.Position - obj.Position).Magnitude / 3)
                        if F.ESPFlower then
                            local label = obj.Name == "Flower1" and "Blue Flower" or "Red Flower"
                            local col   = obj.Name == "Flower1" and Color3.fromRGB(0, 0, 255) or Color3.fromRGB(255, 0, 0)
                            SetBB(obj, tag, col, label .. "\n" .. dist .. " M")
                        else DelBB(obj, tag) end
                    end
                end)
            end
        end)
    end
end)

