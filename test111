local TweenSpeed  = 250
local currentTween = nil
local SpawnCF = CFrame.new(3823.95, 5.82, -1919.74, 0.088467, 0, 0.996079, 0, 1, 0, -0.996079, 0, 0.088467)

local function SmartTweenTo(targetCF)
    local hrp = GetHRP() if not hrp then return end
    local tp  = targetCF.Position
    if (SpawnCF.Position - tp).Magnitude < (hrp.Position - tp).Magnitude then
        hrp.CFrame = SpawnCF task.wait(0.1)
    end
    if currentTween and currentTween.PlaybackState == Enum.PlaybackState.Playing then
        currentTween:Cancel()
    end
    local dist = (hrp.Position - tp).Magnitude
    currentTween = TweenService:Create(hrp,
        TweenInfo.new(dist / TweenSpeed, Enum.EasingStyle.Linear),
        {CFrame = targetCF + Vector3.new(0, 3, 0)})
    currentTween:Play()
    currentTween.Completed:Wait()
end

