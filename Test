-- Optimized GetIcon with caching
function redzlib:GetIcon(index, fallback)
    self.Stats.IconLookups = self.Stats.IconLookups + 1
    
    if type(index) ~= "string" or index:find("rbxassetid://") or #index == 0 then 
        return index or fallback or "" 
    end
    
    if IconCache[index] then
        self.Stats.IconCacheHits = self.Stats.IconCacheHits + 1
        return IconCache[index]
    end
    
    local cleaned = string.lower(index):gsub("lucide", ""):gsub("[-_ ]", "")
    
    if self.Icons[cleaned] then 
        CacheIcon(index, self.Icons[cleaned])
        return self.Icons[cleaned] 
    end
    
    for name, assetId in pairs(self.Icons) do
        if string.lower(name):find(cleaned, 1, true) then 
            CacheIcon(index, assetId)
            return assetId 
        end
    end
    
    local originalLower = string.lower(index)
    if self.Icons[originalLower] then 
        CacheIcon(index, self.Icons[originalLower])
        return self.Icons[originalLower] 
    end
    
    return fallback or index
end

function redzlib:RegisterIcon(name, assetId)
    if type(name) ~= "string" or type(assetId) ~= "string" then return false end
    local normalized = string.lower(name):gsub("[-_ ]", "")
    self.Icons[name] = assetId
    self.Icons[normalized] = assetId
    IconCache[name] = assetId
    IconCache[normalized] = assetId
    return true
end

function redzlib:RegisterIcons(iconTable)
    if type(iconTable) ~= "table" then return 0 end
    local count = 0    for name, assetId in pairs(iconTable) do
        if self:RegisterIcon(name, assetId) then count = count + 1 end
    end
    return count
end

function redzlib:GetIconList()
    local list = {}
    for name in pairs(self.Icons) do table.insert(list, name) end
    table.sort(list)
    return list
end

function redzlib:ImportLucideIcons(iconMappingTable)
    if type(iconMappingTable) ~= "table" then return 0 end
    return self:RegisterIcons(iconMappingTable)
end

