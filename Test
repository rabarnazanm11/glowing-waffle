    local ButtonsFolder = Create("Folder", TopBar, { Name = "Buttons" })
    local CloseButton = Create("ImageButton", {
        Size = UDim2.new(0, 14, 0, 14), Position = UDim2.new(1, -10, 0.5),
        AnchorPoint = Vector2.new(1, 0.5), BackgroundTransparency = 1,
        Image = "rbxassetid://10747384394", AutoButtonColor = false, Name = "Close",
    })
    local MinimizeButton = SetProps(CloseButton:Clone(), {
        Position = UDim2.new(1, -35, 0.5), Image = "rbxassetid://10734896206", Name = "Minimize",
    })
    for _, btn in ipairs({ CloseButton, MinimizeButton }) do
        btn.MouseEnter:Connect(function() Tween(btn, { ImageTransparency = 0.3 }, 0.1) end)
        btn.MouseLeave:Connect(function() Tween(btn, { ImageTransparency = 0   }, 0.15) end)
    end
    SetChildren(ButtonsFolder, { CloseButton, MinimizeButton })

    local Minimized, SaveSize, WaitClick
    local Window, FirstTab = {}, false

    function Window:CloseBtn()
        Window:Dialog({
            Title = "Close", Text = "Close the UI?",
            Options = {
                { "Confirm", function() ScreenGui:Destroy() end },
                { "Cancel" },
            },
        })
    end
    function Window:MinimizeBtn()
        if WaitClick then return end        WaitClick = true
        if Minimized then
            MinimizeButton.Image = "rbxassetid://10734896206"
            CreateTween({ MainFrame, "Size", SaveSize, 0.25, true })
            ControlSize1.Visible, ControlSize2.Visible = true, true
            Minimized = false
        else
            MinimizeButton.Image = "rbxassetid://10734924532"
            SaveSize = MainFrame.Size
            ControlSize1.Visible, ControlSize2.Visible = false, false
            CreateTween({ MainFrame, "Size", UDim2.fromOffset(MainFrame.Size.X.Offset, 28), 0.25, true })
            Minimized = true
        end
        WaitClick = false
    end
    function Window:Minimize() MainFrame.Visible = not MainFrame.Visible end
    function Window:Set(Val1, Val2)
        if type(Val1) == "string" and type(Val2) == "string" then Title.Text = Val1; Title.SubTitle.Text = Val2
        elseif type(Val1) == "string" then Title.Text = Val1 end
    end
    function Window:Dialog(Configs)
        if MainFrame:FindFirstChild("Dialog") then return end
        if Minimized then Window:MinimizeBtn() end
        local DTitle   = Configs[1] or Configs.Title   or "Dialog"
        local DText    = Configs[2] or Configs.Text    or "This is a Dialog"
        local DOptions = Configs[3] or Configs.Options or {}
        local Frame = Create("Frame", {
            Active = true, Size = UDim2.fromOffset(270, 162),
            Position = UDim2.fromScale(0.5, 0.5), AnchorPoint = Vector2.new(0.5, 0.5),
        }, {
            InsertTheme(Create("TextLabel", {
                Font = Enum.Font.GothamBold, Size = UDim2.new(1, 0, 0, 20),
                Text = DTitle, TextXAlignment = "Left", TextColor3 = Theme["Color Text"],
                TextSize = 15, Position = UDim2.fromOffset(15, 5), BackgroundTransparency = 1,
            }), "Text"),
            InsertTheme(Create("TextLabel", {
                Font = Enum.Font.GothamMedium, Size = UDim2.new(1, -25, 0, 0), AutomaticSize = "Y",
                Text = DText, TextXAlignment = "Left", TextColor3 = Theme["Color Dark Text"],
                TextSize = 12, Position = UDim2.fromOffset(15, 25), BackgroundTransparency = 1, TextWrapped = true,
            }), "DarkText"),
        })
        Make("Gradient", Frame, { Rotation = 270 })
        Make("Corner",   Frame)
        local ButtonsHolder = Create("Frame", Frame, {
            Size = UDim2.fromScale(1, 0.35), Position = UDim2.fromScale(0, 1),
            AnchorPoint = Vector2.new(0, 1), BackgroundTransparency = 1,
        }, {
            Create("UIListLayout", {
                Padding = UDim.new(0, 10), VerticalAlignment = "Center",
                FillDirection = "Horizontal", HorizontalAlignment = "Center",            }),
        })
        local Screen = InsertTheme(Create("Frame", MainFrame, {
            BackgroundTransparency = 0.6, Active = true, BackgroundColor3 = Theme["Color Stroke"],
            Size = UDim2.new(1, 0, 1, 0), Name = "Dialog",
        }), "Stroke")
        MainCorner:Clone().Parent = Screen
        Frame.Parent = Screen
        Frame.BackgroundTransparency = 1
        Frame.Size = UDim2.fromOffset(220, 130)
        Tween(Frame,  { Size = UDim2.fromOffset(250, 150), BackgroundTransparency = 0 }, 0.22, Enum.EasingStyle.Back)
        Tween(Screen, { BackgroundTransparency = 0.3 }, 0.15)
        local ButtonCount = 1
        local Dialog = {}
        function Dialog:Button(Cfg)
            local BName = Cfg[1] or Cfg.Name or ""; local BCB = Cfg[2] or Cfg.Callback or function() end
            ButtonCount = ButtonCount + 1
            local Btn = Make("Button", ButtonsHolder)
            Make("Corner", Btn)
            SetProps(Btn, { Text = BName, Font = Enum.Font.GothamBold, TextColor3 = Theme["Color Text"], TextSize = 12 })
            for _, B in pairs(ButtonsHolder:GetChildren()) do
                if B:IsA("TextButton") then
                    B.Size = UDim2.new(1/ButtonCount, -(((ButtonCount-1)*20)/ButtonCount), 0, 32)
                end
            end
            Btn.Activated:Connect(Dialog.Close); Btn.Activated:Connect(BCB)
        end
        function Dialog:Close()
            Tween(Frame,  { Size = UDim2.fromOffset(270, 162), BackgroundTransparency = 1 }, 0.18, Enum.EasingStyle.Quint)
            Tween(Screen, { BackgroundTransparency = 1 }, 0.15)
            task.delay(0.2, function() pcall(Screen.Destroy, Screen) end)
        end
        for _, Btn in ipairs(DOptions) do Dialog:Button(Btn) end
        return Dialog
    end
    function Window:SelectTab(TabSelect)
        if type(TabSelect) == "number" then
            if redzlib.Tabs[TabSelect] then redzlib.Tabs[TabSelect].func:Enable() end
        else
            for _, Tab in pairs(redzlib.Tabs) do
                if Tab.Cont == TabSelect.Cont then Tab.func:Enable() end
            end
        end
    end
    function Window:MakeFloatButton(icon)
        local iconId = redzlib:GetIcon(type(icon) == "string" and icon or "sword")
        local FloatGui = Instance.new("ScreenGui")
        FloatGui.Name = "FloatHubBtn"; FloatGui.ResetOnSpawn = false
        FloatGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
        FloatGui.IgnoreGuiInset = true; FloatGui.DisplayOrder = 999        FloatGui.Parent = CoreGui
        local Pill = Instance.new("TextButton")
        Pill.Name = "FloatPill"; Pill.Size = UDim2.fromOffset(42, 42)
        Pill.Position = UDim2.fromOffset(30, 50); Pill.AnchorPoint = Vector2.new(0, 0.5)
        Pill.BackgroundColor3 = Color3.fromRGB(18,18,18); Pill.AutoButtonColor = false
        Pill.Active = true; Pill.Text = ""; Pill.ZIndex = 5; Pill.Parent = FloatGui
        local corner = Instance.new("UICorner"); corner.CornerRadius = UDim.new(0.5,0); corner.Parent = Pill
        local stroke = Instance.new("UIStroke"); stroke.Color = Color3.fromRGB(88,101,242)
        stroke.Thickness = 1.8; stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; stroke.Parent = Pill
        local grad = Instance.new("UIGradient")
        grad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(28,28,28)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(38,38,48)),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(18,18,18)),
        })
        grad.Rotation = 90; grad.Parent = Pill
        local Icon = Instance.new("ImageLabel"); Icon.Size = UDim2.fromOffset(22,22)
        Icon.Position = UDim2.fromScale(0.5,0.5); Icon.AnchorPoint = Vector2.new(0.5,0.5)
        Icon.BackgroundTransparency = 1; Icon.Image = iconId
        Icon.ImageColor3 = Color3.fromRGB(88,101,242); Icon.ZIndex = 6; Icon.Parent = Pill
        task.spawn(function()
            while FloatGui.Parent do
                TweenService:Create(stroke, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { Transparency = 0.55 }):Play()
                task.wait(1.4)
                TweenService:Create(stroke, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { Transparency = 0 }):Play()
                task.wait(1.4)
            end
        end)
        Pill.MouseEnter:Connect(function()
            TweenService:Create(Pill, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(30,30,45) }):Play()
            TweenService:Create(stroke, TweenInfo.new(0.15), { Transparency = 0 }):Play()
            TweenService:Create(Icon, TweenInfo.new(0.15), { ImageColor3 = Color3.fromRGB(160,170,255) }):Play()
        end)
        Pill.MouseLeave:Connect(function()
            TweenService:Create(Pill, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(18,18,18) }):Play()
            TweenService:Create(Icon, TweenInfo.new(0.15), { ImageColor3 = Color3.fromRGB(88,101,242) }):Play()
        end)
        local THRESHOLD = 10; local pressing, wasDragged, dragStart, startOffset = false, false, nil, nil
        Pill.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
            and input.UserInputType ~= Enum.UserInputType.Touch then return end
            pressing = true; wasDragged = false
            dragStart = UserInputService:GetMouseLocation()
            startOffset = Vector2.new(Pill.Position.X.Offset, Pill.Position.Y.Offset)
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
            and input.UserInputType ~= Enum.UserInputType.Touch then return end
            if not pressing then return end
            if not wasDragged then                TweenService:Create(Pill, TweenInfo.new(0.08), { BackgroundColor3 = Color3.fromRGB(88,101,242) }):Play()
                task.delay(0.08, function()
                    TweenService:Create(Pill, TweenInfo.new(0.2), { BackgroundColor3 = Color3.fromRGB(18,18,18) }):Play()
                end)
                Window:Minimize()
            end
            pressing = false; wasDragged = false; dragStart = nil
        end)
        RunService.Heartbeat:Connect(function()
            if not pressing or not dragStart then return end
            local delta = UserInputService:GetMouseLocation() - dragStart
            if delta.Magnitude >= THRESHOLD then
                wasDragged = true
                Pill.Position = UDim2.fromOffset(startOffset.X + delta.X, startOffset.Y + delta.Y)
            end
        end)
        return Pill
    end

    -- ════════════════════════════════════════════════════════════════════════
    --  MakeTab (unchanged - uses enhanced GetIcon internally)
    -- ════════════════════════════════════════════════════════════════════════
    local ContainerList = {}

    function Window:MakeTab(Configs)
        if type(Configs) ~= "table" then Configs = { Configs } end
        local TName = Configs[1] or Configs.Title or Configs.Name or "Tab"
        local TIcon = Configs[2] or Configs.Icon  or ""
        TIcon = redzlib:GetIcon(TIcon)  -- ✅ Uses enhanced GetIcon with Lucide support
        if not TIcon:find("rbxassetid://") or #TIcon:gsub("rbxassetid://", "") < 6 then TIcon = false end

        local TabSelect = Make("Button", MainScroll, { Size = UDim2.new(1, 0, 0, 24) })
        Make("Corner", TabSelect)
        local isFirst = not FirstTab
        local LabelTitle = InsertTheme(Create("TextLabel", TabSelect, {
            Size = UDim2.new(1, TIcon and -25 or -15, 1),
            Position = UDim2.fromOffset(TIcon and 25 or 15),
            BackgroundTransparency = 1, Font = Enum.Font.GothamMedium,
            Text = TName, TextColor3 = Theme["Color Text"], TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTransparency = isFirst and 0 or 0.3, TextTruncate = "AtEnd",
        }), "Text")
        local LabelIcon = InsertTheme(Create("ImageLabel", TabSelect, {
            Position = UDim2.new(0, 8, 0.5), Size = UDim2.new(0, 13, 0, 13),
            AnchorPoint = Vector2.new(0, 0.5), Image = TIcon or "",
            BackgroundTransparency = 1, ImageTransparency = isFirst and 0 or 0.3,
        }), "Text")
        local Selected = InsertTheme(Create("Frame", TabSelect, {
            Size = isFirst and UDim2.new(0,4,0,13) or UDim2.new(0,4,0,4),
            Position = UDim2.new(0, 1, 0.5), AnchorPoint = Vector2.new(0, 0.5),            BackgroundColor3 = Theme["Color Theme"],
            BackgroundTransparency = isFirst and 0 or 1,
        }), "Theme")
        Make("Corner", Selected, UDim.new(0.5, 0))

        local Container = InsertTheme(Create("ScrollingFrame", {
            Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0, 0, 1),
            AnchorPoint = Vector2.new(0, 1), ScrollBarThickness = 1.5,
            BackgroundTransparency = 1, ScrollBarImageTransparency = 0.2,
            ScrollBarImageColor3 = Theme["Color Theme"], AutomaticCanvasSize = "Y",
            ScrollingDirection = "Y", BorderSizePixel = 0, CanvasSize = UDim2.new(),
            Name = ("Container %i [%s]"):format(#ContainerList + 1, TName),
        }, {
            Create("UIPadding", {
                PaddingLeft = UDim.new(0,10), PaddingRight  = UDim.new(0,10),
                PaddingTop  = UDim.new(0,10), PaddingBottom = UDim.new(0,10),
            }),
            Create("UIListLayout", { Padding = UDim.new(0, 5) }),
        }), "ScrollBar")
        table.insert(ContainerList, Container)
        if not FirstTab then Container.Parent = Containers end

        local function EnableTab()
            if Container.Parent then return end
            for _, Frame in ipairs(ContainerList) do
                if Frame:IsA("ScrollingFrame") and Frame ~= Container then Frame.Parent = nil end
            end
            Container.Parent = Containers
            Container.Size = UDim2.new(1, 0, 1, 0)
            Container.BackgroundTransparency = 1
            for _, child in ipairs(Container:GetDescendants()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("Frame") then
                    if child.BackgroundTransparency < 1 then
                        local origT = child.BackgroundTransparency
                        child.BackgroundTransparency = 1
                        Tween(child, { BackgroundTransparency = origT }, 0.2, Enum.EasingStyle.Quad)
                    end
                end
            end
            for _, Tab in pairs(redzlib.Tabs) do
                if Tab.Cont ~= Container then Tab.func:Disable() end
            end
            Tween(LabelTitle, { TextTransparency = 0    }, 0.3, Enum.EasingStyle.Quint)
            Tween(LabelIcon,  { ImageTransparency = 0   }, 0.3, Enum.EasingStyle.Quint)
            Tween(Selected,   { Size = UDim2.new(0,4,0,13), BackgroundTransparency = 0 }, 0.3, Enum.EasingStyle.Back)
        end
        TabSelect.Activated:Connect(EnableTab)
        FirstTab = true

        local Tab = {}        table.insert(redzlib.Tabs, { TabInfo = { Name = TName, Icon = TIcon }, func = Tab, Cont = Container })
        Tab.Cont = Container

        function Tab:Disable()
            Container.Parent = nil
            Tween(LabelTitle, { TextTransparency = 0.3               }, 0.3, Enum.EasingStyle.Quint)
            Tween(LabelIcon,  { ImageTransparency = 0.3              }, 0.3, Enum.EasingStyle.Quint)
            Tween(Selected,   { Size = UDim2.new(0,4,0,4), BackgroundTransparency = 1 }, 0.3, Enum.EasingStyle.Quint)
        end
        function Tab:Enable()  EnableTab() end
        function Tab:Visible(Bool)
            Funcs:ToggleVisible(TabSelect, Bool)
            if Bool ~= nil then Container.Parent = Bool and Containers or nil end
        end
        function Tab:Destroy() TabSelect:Destroy(); Container:Destroy() end

        function Tab:AddSection(cfg)       return CreateSection(Container, cfg)                          end
        function Tab:AddSeparator()        return CreateSeparator(Container)                             end
        function Tab:AddParagraph(cfg)     return CreateParagraph(Container, cfg)                        end
        function Tab:AddButton(cfg)        return CreateButton(Container, cfg)                           end
        function Tab:AddToggle(cfg)        return CreateToggle(Container, cfg)                           end
        function Tab:AddDropdown(cfg)      return CreateDropdown(Container, cfg, DropdownHolder)         end
        function Tab:AddSlider(cfg)        return CreateSlider(Container, cfg)                           end
        function Tab:AddTextBox(cfg)       return CreateTextBox(Container, cfg)                          end
        function Tab:AddKeybind(cfg)       return CreateKeybind(Container, cfg)                          end
        function Tab:AddColorPicker(cfg)   return CreateColorPicker(Container, cfg)                      end
        function Tab:AddDiscordInvite(cfg) return CreateDiscordInvite(Container, cfg)                    end

        function Tab:AddHorizontalPanels(leftTitle, rightTitle)
            local HFrame = Create("Frame", Container, {
                Size                 = UDim2.new(1, 0, 0, 0),
                AutomaticSize        = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
                Name                 = "HorizontalPanels",
            })
            Create("UIListLayout", HFrame, {
                FillDirection       = Enum.FillDirection.Horizontal,
                HorizontalAlignment = Enum.HorizontalAlignment.Center,
                VerticalAlignment   = Enum.VerticalAlignment.Top,
                Padding             = UDim.new(0, 8),
                SortOrder           = Enum.SortOrder.LayoutOrder,
            })
            local LeftPanel  = CreatePanel(HFrame, leftTitle  or "Left",  DropdownHolder)
            local RightPanel = CreatePanel(HFrame, rightTitle or "Right", DropdownHolder)
            return LeftPanel, RightPanel
        end

        return Tab
    end
    CloseButton.Activated:Connect(function()    Window:CloseBtn()    end)
    MinimizeButton.Activated:Connect(function() Window:MinimizeBtn() end)
    return Window
end

return redzlib
