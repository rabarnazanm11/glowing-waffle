--  ColorPicker — v1.5.0 improvements:
--   • inp.Position for accurate initial click (fixes mobile/touch offset)
--   • Larger 130×130 SV square
--   • Smooth cursor tween on :Set()
--   • Prettier hue needle, better panel layout
-- ════════════════════════════════════════════════════════════════════════════
local function CreateColorPicker(parent, configs)
    local CName    = configs[1] or configs.Name  or configs.Title or "Color"
    local CDesc    = configs.Desc or configs.Description or ""
    local Default  = configs[2] or configs.Default or Color3.fromRGB(255, 255, 255)
    local Flag     = configs[4] or configs.Flag    or false
    local Callback = Funcs:GetCallback(configs, 3)

    if CheckFlag(Flag) then
        local saved = GetFlag(Flag)
        if type(saved) == "table" and saved.r then
            Default = Color3.new(
                math.clamp(tonumber(saved.r) or 1, 0, 1),
                math.clamp(tonumber(saved.g) or 1, 0, 1),
                math.clamp(tonumber(saved.b) or 1, 0, 1)
            )
        end
    end

    local curH, curS, curV = Color3.toHSV(Default)
    local currentColor     = Default

    -- Layout constants — enlarged SV square
    local SV_SZ   = 130
    local HUE_W   = 16
    local MARGIN  = 10
    local GAP     = 8
    local INFO_X  = MARGIN + SV_SZ + GAP + HUE_W + GAP
    local PANEL_H = SV_SZ + MARGIN * 2 + 10  -- 158px

    -- ── Header row ──────────────────────────────────────────────────────────
    local Button, LabelFunc = ButtonFrame(parent, CName, CDesc, UDim2.new(1, -52))

    local Swatch = Create("Frame", Button, {
        Size             = UDim2.new(0, 30, 0, 17),
        Position         = UDim2.new(1, -10, 0.5),
        AnchorPoint      = Vector2.new(1, 0.5),
        BackgroundColor3 = currentColor,
        BorderSizePixel  = 0,
    })
    Make("Corner", Swatch, UDim.new(0, 5))
    Make("Stroke",  Swatch)

    local Arrow = Create("ImageLabel", Button, {
        Size                 = UDim2.new(0, 12, 0, 12),
        Position             = UDim2.new(1, -46, 0.5),
        AnchorPoint          = Vector2.new(0, 0.5),
        BackgroundTransparency = 1,
        Image                = "rbxassetid://10709791523",
    })

    -- ── Expandable panel ────────────────────────────────────────────────────
    local Panel = InsertTheme(Create("Frame", parent, {
        Name                 = "CP_" .. CName,
        Size                 = UDim2.new(1, 0, 0, 0),
        BackgroundColor3     = Theme["Color Hub 2"],
        ClipsDescendants     = true,
        BorderSizePixel      = 0,
    }), "Frame")
    Make("Corner",   Panel)
    Make("Stroke",   Panel)
    Make("Gradient", Panel, { Rotation = 45 })

    -- ── SV Square ───────────────────────────────────────────────────────────
    local SVOuter = Create("Frame", Panel, {
        Size             = UDim2.new(0, SV_SZ, 0, SV_SZ),
        Position         = UDim2.fromOffset(MARGIN, MARGIN),
        BackgroundColor3 = Color3.fromHSV(curH, 1, 1),
        BorderSizePixel  = 0,
        ClipsDescendants = true,
    })
    Make("Corner", SVOuter, UDim.new(0, 5))
    -- White-left (saturation) gradient
    local WhiteLayer = Create("Frame", SVOuter, {
        Size = UDim2.fromScale(1, 1), BackgroundColor3 = Color3.new(1,1,1), BorderSizePixel = 0,
    })
    Create("UIGradient", WhiteLayer, {
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(1, 1),
        }),
        Rotation = 0,
    })
    -- Black-bottom (value) gradient
    local BlackLayer = Create("Frame", SVOuter, {
        Size = UDim2.fromScale(1, 1), BackgroundColor3 = Color3.new(0,0,0), BorderSizePixel = 0,
    })
    Create("UIGradient", BlackLayer, {
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        }),
        Rotation = 90,
    })
    -- Cursor circle
    local SVCursor = Create("Frame", SVOuter, {
        Size             = UDim2.new(0, 11, 0, 11),
        AnchorPoint      = Vector2.new(0.5, 0.5),
        Position         = UDim2.new(curS, 0, 1 - curV, 0),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel  = 0,
        ZIndex           = 5,
    })
    Make("Corner", SVCursor, UDim.new(0.5, 0))
    Make("Stroke",  SVCursor)

    -- ── Hue Bar ─────────────────────────────────────────────────────────────
    local HueBar = Create("Frame", Panel, {
        Size             = UDim2.new(0, HUE_W, 0, SV_SZ),
        Position         = UDim2.fromOffset(MARGIN + SV_SZ + GAP, MARGIN),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel  = 0,
        ClipsDescendants = true,
    })
    Make("Corner", HueBar, UDim.new(0, 5))
    local hueKpts = {}
    for i = 0, 6 do hueKpts[i+1] = ColorSequenceKeypoint.new(i/6, Color3.fromHSV(i/6, 1, 1)) end
    Create("UIGradient", HueBar, { Color = ColorSequence.new(hueKpts), Rotation = 90 })

    -- Hue needle: a thin line with outer glow effect
    local HueLine = Create("Frame", HueBar, {
        Size             = UDim2.new(1, 0, 0, 3),
        Position         = UDim2.new(0, 0, curH, 0),
        AnchorPoint      = Vector2.new(0, 0.5),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel  = 0,
        ZIndex           = 5,
    })
    Create("UICorner", HueLine, { CornerRadius = UDim.new(0.5, 0) })
    local HueStroke = Create("UIStroke", HueLine, {
        Color     = Color3.new(0, 0, 0),
        Thickness = 1,
        ApplyStrokeMode = "Border",
    })

    -- ── Info column ─────────────────────────────────────────────────────────
    local PreviewBig = Create("Frame", Panel, {
        Size             = UDim2.new(0, 50, 0, 26),
        Position         = UDim2.fromOffset(INFO_X, MARGIN),
        BackgroundColor3 = currentColor,
        BorderSizePixel  = 0,
    })
    Make("Corner", PreviewBig, UDim.new(0, 5))
    Make("Stroke",  PreviewBig)

    local HexLabel = InsertTheme(Create("TextLabel", Panel, {
        Size = UDim2.new(0, 70, 0, 14),
        Position = UDim2.fromOffset(INFO_X, MARGIN + 32),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold, TextSize = 10,
        TextXAlignment = "Left", TextColor3 = Theme["Color Text"], Text = "#FFFFFF",
    }), "Text")

    local function makeInfoLabel(yOff, txt)
        return InsertTheme(Create("TextLabel", Panel, {
            Size = UDim2.new(0, 70, 0, 13),
            Position = UDim2.fromOffset(INFO_X, MARGIN + yOff),
            BackgroundTransparency = 1,
            Font = Enum.Font.Gotham, TextSize = 9,
            TextXAlignment = "Left", TextColor3 = Theme["Color Dark Text"], Text = txt,
        }), "DarkText")
    end
    local RLabel = makeInfoLabel(52, "R 255")
    local GLabel = makeInfoLabel(67, "G 255")
    local BLabel = makeInfoLabel(82, "B 255")

    -- ── Core update function ─────────────────────────────────────────────────
    local function applyColor(h, s, v, animate)
        curH, curS, curV = h, s, v
        currentColor = Color3.fromHSV(h, s, v)
        local r = math.floor(currentColor.R * 255 + 0.5)
        local g = math.floor(currentColor.G * 255 + 0.5)
        local b = math.floor(currentColor.B * 255 + 0.5)
        SVOuter.BackgroundColor3    = Color3.fromHSV(h, 1, 1)
        Swatch.BackgroundColor3     = currentColor
        PreviewBig.BackgroundColor3 = currentColor
        HexLabel.Text = string.format("#%02X%02X%02X", r, g, b)
        RLabel.Text   = "R " .. r
        GLabel.Text   = "G " .. g
        BLabel.Text   = "B " .. b
        if animate then
            Tween(SVCursor, { Position = UDim2.new(s, 0, 1-v, 0) }, 0.18, Enum.EasingStyle.Quint)
            Tween(HueLine,  { Position = UDim2.new(0, 0, h, 0)    }, 0.18, Enum.EasingStyle.Quint)
        else
            SVCursor.Position = UDim2.new(s, 0, 1 - v, 0)
            HueLine.Position  = UDim2.new(0, 0, h, 0)
        end
        SetFlag(Flag, { r = currentColor.R, g = currentColor.G, b = currentColor.B })
        Funcs:FireCallback(Callback, currentColor)
    end
    applyColor(curH, curS, curV, false)

    -- ── Accurate position helpers ────────────────────────────────────────────
    local function getSVCoords(px, py)
        local abs = SVOuter.AbsolutePosition
        local sz  = SVOuter.AbsoluteSize
        return math.clamp((px - abs.X) / sz.X, 0, 1),
               math.clamp(1 - (py - abs.Y) / sz.Y, 0, 1)
    end
    local function getHueCoord(py)
        local abs = HueBar.AbsolutePosition
        local sz  = HueBar.AbsoluteSize
        return math.clamp((py - abs.Y) / sz.Y, 0, 1)
    end

    -- ── SV drag ─────────────────────────────────────────────────────────────
    local svDown = false
    SVOuter.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            svDown = true
            -- Use inp.Position for accurate initial touch/click
            local s2, v2 = getSVCoords(inp.Position.X, inp.Position.Y)
            applyColor(curH, s2, v2, false)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then svDown = false end
    end)
    RunService.Heartbeat:Connect(function()
        if svDown then
            local ml = UserInputService:GetMouseLocation()
            local s2, v2 = getSVCoords(ml.X, ml.Y)
            applyColor(curH, s2, v2, false)
        end
    end)

    -- ── Hue drag ─────────────────────────────────────────────────────────────
    local hueDown = false
    HueBar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            hueDown = true
            -- Use inp.Position for accurate initial touch/click
            local h2 = getHueCoord(inp.Position.Y)
            applyColor(h2, curS, curV, false)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then hueDown = false end
    end)
    RunService.Heartbeat:Connect(function()
        if hueDown then
            local ml = UserInputService:GetMouseLocation()
            local h2 = getHueCoord(ml.Y)
            applyColor(h2, curS, curV, false)
        end
    end)

    -- ── Toggle open/close ────────────────────────────────────────────────────
    local open     = false
    local waitPick = false
    local function togglePicker()
        if waitPick then return end
        waitPick = true
        open = not open
        if open then
            Tween(Panel,  { Size = UDim2.new(1, 0, 0, PANEL_H) }, 0.28, Enum.EasingStyle.Back)
            Tween(Arrow,  { Rotation = 180 },                      0.22, Enum.EasingStyle.Quint)
        else
            Tween(Panel,  { Size = UDim2.new(1, 0, 0, 0) },        0.22, Enum.EasingStyle.Quint)
            Tween(Arrow,  { Rotation = 0 },                         0.22, Enum.EasingStyle.Quint)
        end
        waitPick = false
    end
    Button.Activated:Connect(togglePicker)

