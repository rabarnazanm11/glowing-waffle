local function CreateKeybind(parent, configs)
    local KName    = configs[1] or configs.Name  or configs.Title or "Keybind"
    local KDesc    = configs.Desc or configs.Description or ""
    local Default  = configs[2] or configs.Default or Enum.KeyCode.Unknown
    local Flag     = configs[4] or configs.Flag or false
    local Callback = Funcs:GetCallback(configs, 3)
    if CheckFlag(Flag) then
        local saved = GetFlag(Flag)
        if type(saved) == "string" and Enum.KeyCode[saved] then Default = Enum.KeyCode[saved] end
    end
    local CurrentKey = Default
    local Listening  = false
    local Button, LabelFunc = ButtonFrame(parent, KName, KDesc, UDim2.new(1, -100))
    local KeyHolder = InsertTheme(Create("TextButton", Button, {
        Size = UDim2.new(0, 80, 0, 18), Position = UDim2.new(1, -10, 0.5),
        AnchorPoint = Vector2.new(1, 0.5), BackgroundColor3 = Theme["Color Stroke"],
        Font = Enum.Font.GothamBold, TextSize = 9, TextColor3 = Theme["Color Text"],
        Text = CurrentKey.Name, AutoButtonColor = false,
    }), "Stroke")
    Make("Corner", KeyHolder, UDim.new(0, 4))
    AddPressAnim(KeyHolder)
    local function SetKey(key)
        CurrentKey = key; KeyHolder.Text = key.Name; Listening = false
        Tween(KeyHolder, { BackgroundColor3 = Theme["Color Stroke"] }, 0.15)
        SetFlag(Flag, key.Name)
        Funcs:FireCallback(Callback, key)
    end
    KeyHolder.Activated:Connect(function()
        if Listening then
            Listening = false; KeyHolder.Text = CurrentKey.Name
            Tween(KeyHolder, { BackgroundColor3 = Theme["Color Stroke"] }, 0.15)
        else
            Listening = true; KeyHolder.Text = "..."
            Tween(KeyHolder, { BackgroundColor3 = Theme["Color Theme"] }, 0.15)
        end
    end)
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not Listening or gpe then return end
        if input.UserInputType == Enum.UserInputType.Keyboard then SetKey(input.KeyCode) end
    end)
    local Keybind = {}
    function Keybind:Set(val)
        if typeof(val) == "EnumItem" then SetKey(val)
        elseif type(val) == "string" and Enum.KeyCode[val] then SetKey(Enum.KeyCode[val]) end
    end
    function Keybind:GetKey()     return CurrentKey                end
    function Keybind:Visible(...) Funcs:ToggleVisible(Button, ...) end
    function Keybind:Destroy()    Button:Destroy()                 end
    return Keybind
end
