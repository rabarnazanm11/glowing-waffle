function redzlib:GetIcon(index, fallback)
    -- Return early if already a valid asset ID or empty
    if type(index) ~= "string" or index:find("rbxassetid://") or #index == 0 then 
        return index or fallback or ""     end
    
    -- Normalize: remove "lucide" prefix, convert to lowercase, strip hyphens/underscores/spaces
    local cleaned = string.lower(index):gsub("lucide", ""):gsub("[-_ ]", "")
    
    -- Direct lookup with normalized key
    if self.Icons[cleaned] then return self.Icons[cleaned] end
    
    -- Fuzzy match: case-insensitive substring search
    for name, assetId in pairs(self.Icons) do
        if string.lower(name):find(cleaned, 1, true) then return assetId end
    end
    
    -- Try original kebab-case variant (e.g., "arrow-down" → check "arrow-down" key)
    local originalLower = string.lower(index)
    if self.Icons[originalLower] then return self.Icons[originalLower] end
    
    -- Return fallback if provided, otherwise return original input unchanged
    return fallback or index
end

-- NEW: Register a single custom icon at runtime
function redzlib:RegisterIcon(name, assetId)
    if type(name) ~= "string" or type(assetId) ~= "string" then return false end
    local normalized = string.lower(name):gsub("[-_ ]", "")
    self.Icons[name] = assetId
    self.Icons[normalized] = assetId
    return true
end

-- NEW: Register multiple icons from a table { ["icon-name"] = "rbxassetid://..." }
function redzlib:RegisterIcons(iconTable)
    if type(iconTable) ~= "table" then return 0 end
    local count = 0
    for name, assetId in pairs(iconTable) do
        if self:RegisterIcon(name, assetId) then count = count + 1 end
    end
    return count
end

-- NEW: Get sorted list of all available icon names (for icon pickers/debugging)
function redzlib:GetIconList()
    local list = {}
    for name in pairs(self.Icons) do table.insert(list, name) end
    table.sort(list)
    return list
end

-- NEW: Bulk import helper - paste your uploaded asset ID mappings here
function redzlib:ImportLucideIcons(iconMappingTable)    -- Example usage:
    -- redzlib:ImportLucideIcons({
    --     ["home"] = "rbxassetid://123456789",
    --     ["settings"] = "rbxassetid://987654321",
    -- })
    if type(iconMappingTable) ~= "table" then return 0 end
    return self:RegisterIcons(iconMappingTable)
end

