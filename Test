-- CreateTween — legacy compatible wrapper
local function CreateTween(Configs)
    local Inst   = Configs[1] or Configs.Instance
    local Prop   = Configs[2] or Configs.Prop
    local NewVal = Configs[3] or Configs.NewVal
    local Time   = Configs[4] or Configs.Time or 0.5
    local DoWait = Configs[5] or Configs.wait or false
    local t = TweenService:Create(Inst, TweenInfo.new(Time, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), { [Prop] = NewVal })
    t:Play()
    if DoWait then t.Completed:Wait() end
    return t
end

