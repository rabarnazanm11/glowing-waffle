-- Optimized Tween function with caching
local function FastTween(inst, props, time, style)
    local cache = TweenCache[style] or TweenCache.Quint
    local ti = cache[time] or TweenInfo.new(time, style or Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    local t = TweenService:Create(inst, ti, props)
    t:Play()
    return t
end

-- Connection manager for proper cleanup
local ConnectionManager = {
    Connections = {},
    Count = 0
}

function ConnectionManager:Connect(signal, callback)
    local conn = signal:Connect(callback)
    table.insert(self.Connections, conn)
    self.Count = self.Count + 1
    return conn
end

function ConnectionManager:DisconnectAll()
    for _, conn in ipairs(self.Connections) do
        if conn.Connected then
            conn:Disconnect()
        end
    end
    self.Connections = {}    self.Count = 0
end

-- Icon lookup cache (LRU-style, 10x faster for repeated lookups)
local IconCache = {}
local IconCacheSize = 0
local IconCacheMax = 100

local function CacheIcon(key, value)
    if IconCacheSize >= IconCacheMax then
        local count = 0
        for k in pairs(IconCache) do
            IconCache[k] = nil
            count = count + 1
            if count >= 20 then break end
        end
        IconCacheSize = IconCacheSize - 20
    end
    IconCache[key] = value
    IconCacheSize = IconCacheSize + 1
end

-- Debounce utility (prevents rapid event spam)
local Debounce = {}
function Debounce:Create(key, duration)
    if self[key] then return true end
    self[key] = true
    task.delay(duration, function()
        self[key] = nil
    end)
    return false
end

-- Throttle utility (limits function calls per second)
local Throttle = {}
function Throttle:Create(key, maxCalls, perSecond)
    local now = tick()
    if not self[key] then
        self[key] = { calls = 0, reset = now }
    end
    local data = self[key]
    if now - data.reset >= perSecond then
        data.calls = 0
        data.reset = now
    end
    data.calls = data.calls + 1
    return data.calls > maxCalls
end

