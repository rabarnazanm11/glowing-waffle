local SetProps, SetChildren, InsertTheme, Create do
    InsertTheme = function(Inst, Type)
        table.insert(redzlib.Instances, { Instance = Inst, Type = Type })
        redzlib.Stats.InstancesCreated = redzlib.Stats.InstancesCreated + 1
        return Inst
    end
    SetChildren = function(Inst, Children)
        if type(Children) == "table" then            for _, Child in ipairs(Children) do Child.Parent = Inst end
        end
        return Inst
    end
    SetProps = function(Inst, Props)
        if type(Props) == "table" then
            for prop, value in pairs(Props) do Inst[prop] = value end
        end
        return Inst
    end
    Create = function(...)
        local args = { ... }
        local new = Instance.new(args[1])
        redzlib.Stats.InstancesCreated = redzlib.Stats.InstancesCreated + 1
        if type(args[2]) == "table" then
            SetProps(new, args[2])
            SetChildren(new, args[3])
        elseif typeof(args[2]) == "Instance" then
            new.Parent = args[2]
            SetProps(new, args[3])
            SetChildren(new, args[4])
        end
        return new
    end
    local function LoadSave(file)
        if not (rawget(_G, "readfile") and rawget(_G, "isfile")) then return end
        local ok, exists = pcall(_G.isfile, file)
        if not ok or not exists then return end
        local ok2, data = pcall(_G.readfile, file)
        if not ok2 then return end
        local ok3, decoded = pcall(HttpService.JSONDecode, HttpService, data)
        if ok3 and type(decoded) == "table" then
            if decoded.UISize  then redzlib.Save.UISize  = decoded.UISize  end
            if decoded.TabSize then redzlib.Save.TabSize = decoded.TabSize end
        end
    end
    pcall(LoadSave, "redz library V5.json")
end

