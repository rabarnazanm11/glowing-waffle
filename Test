--  CreatePanel — v1.5.0
--   • Height-based animated collapse (content wrapper with ClipsDescendants)
--   • Theme-coloured accent bar on header
--   • No element overflow — ClipsDescendants on content
--   • All element types supported
-- ════════════════════════════════════════════════════════════════════════════
local function CreatePanel(parent, title, dropdownHolder)
    -- Outer card
    local PanelFrame = InsertTheme(Create("Frame", parent, {
        Size                 = UDim2.new(0.5, -4, 0, 0),
        AutomaticSize        = Enum.AutomaticSize.None,
        BackgroundColor3     = Theme["Color Hub 2"],
        BorderSizePixel      = 0,
        ClipsDescendants     = false,
    }), "Frame")
    Make("Corner", PanelFrame, UDim.new(0, 7))
    Make("Stroke",  PanelFrame)

    -- Themed accent bar on left edge of header
    local AccentBar = InsertTheme(Create("Frame", PanelFrame, {
        Size             = UDim2.new(0, 3, 0, 14),
        Position         = UDim2.new(0, 6, 0, 6),
        BackgroundColor3 = Theme["Color Theme"],
        BorderSizePixel  = 0,
        ZIndex           = 3,
    }), "Theme")
    Make("Corner", AccentBar, UDim.new(0.5, 0))

    -- Header button
    local Header = InsertTheme(Create("TextButton", PanelFrame, {
        Size             = UDim2.new(1, 0, 0, 26),
        BackgroundColor3 = Theme["Color Hub 2"],
        Text             = "",
        AutoButtonColor  = false,
        ZIndex           = 2,
    }), "Frame")
    Make("Corner", Header, UDim.new(0, 7))
    Header.MouseEnter:Connect(function() Tween(Header, { BackgroundTransparency = 0.4 }, 0.12) end)
    Header.MouseLeave:Connect(function() Tween(Header, { BackgroundTransparency = 0   }, 0.15) end)

    local HeaderLabel = InsertTheme(Create("TextLabel", Header, {
        Size                 = UDim2.new(1, -36, 1, 0),
        Position             = UDim2.new(0, 16, 0, 0),
        BackgroundTransparency = 1,
        Font                 = Enum.Font.GothamBold,
        Text                 = title or "Panel",
        TextColor3           = Theme["Color Text"],
        TextXAlignment       = "Left",
        TextSize             = 10,
        TextTruncate         = "AtEnd",
        ZIndex               = 3,
    }), "Text")

    local CollapseIcon = Create("ImageLabel", Header, {
        Size                 = UDim2.new(0, 12, 0, 12),
        Position             = UDim2.new(1, -14, 0.5),
        AnchorPoint          = Vector2.new(0.5, 0.5),
        BackgroundTransparency = 1,
        Image                = "rbxassetid://10709791523",
        ZIndex               = 3,
    })

    -- Thin divider under header
    local Divider = InsertTheme(Create("Frame", PanelFrame, {
        Size             = UDim2.new(1, -12, 0, 1),
        Position         = UDim2.new(0, 6, 0, 26),
        BackgroundColor3 = Theme["Color Stroke"],
        BorderSizePixel  = 0,
        ZIndex           = 2,
    }), "Stroke")

    -- ── Content wrapper: ClipsDescendants + height tween ────────────────────
    -- This is the frame that we tween the height of for smooth collapse
    local ContentWrap = Create("Frame", PanelFrame, {
        Size                 = UDim2.new(1, 0, 0, 0),  -- starts at 0, will grow
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, 0, 0, 28),
        ClipsDescendants     = true,  -- clips elements during collapse
    })

    -- Inner content with AutomaticSize so it grows as elements are added
    local Content = Create("Frame", ContentWrap, {
        Size                 = UDim2.new(1, 0, 0, 0),
        AutomaticSize        = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
    })
    local Layout = Create("UIListLayout", Content, {
        Padding    = UDim.new(0, 4),
        SortOrder  = Enum.SortOrder.LayoutOrder,
    })
    Create("UIPadding", Content, {
        PaddingLeft   = UDim.new(0, 5),
        PaddingRight  = UDim.new(0, 5),
        PaddingTop    = UDim.new(0, 5),
        PaddingBottom = UDim.new(0, 6),
    })

    -- Track content height and keep ContentWrap synced when expanded
    local contentHeight  = 0
    local collapsed      = false
    local animating      = false

    local function updateHeight()
        contentHeight = Layout.AbsoluteContentSize.Y + 11  -- + padding
        -- Only update wrapper if we are expanded
        if not collapsed then
            ContentWrap.Size  = UDim2.new(1, 0, 0, contentHeight)
            PanelFrame.Size   = UDim2.new(0.5, -4, 0, 28 + contentHeight)
        end
    end
    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateHeight)

    local function SetCollapsed(state)
        if animating then return end
        animating = true
        collapsed = state
        if state then
            -- Collapse: tween wrapper height to 0
            task.spawn(function()
                Tween(CollapseIcon, { Rotation = 180 }, 0.2, Enum.EasingStyle.Quint)
                Tween(AccentBar,    { BackgroundTransparency = 0.5 }, 0.2)
            end)
            local t1 = TweenService:Create(ContentWrap, TI.Quint(0.25), { Size = UDim2.new(1, 0, 0, 0) })
            local t2 = TweenService:Create(PanelFrame,  TI.Quint(0.25), { Size = UDim2.new(0.5, -4, 0, 28) })
            t1:Play(); t2:Play(); t1.Completed:Wait()
        else
            -- Expand: tween wrapper height to content size
            task.spawn(function()
                Tween(CollapseIcon, { Rotation = 0 }, 0.22, Enum.EasingStyle.Back)
                Tween(AccentBar,    { BackgroundTransparency = 0 }, 0.2)
            end)
            local targetH = math.max(contentHeight, 20)
            local t1 = TweenService:Create(ContentWrap, TI.Back(0.28), { Size = UDim2.new(1, 0, 0, targetH) })
            local t2 = TweenService:Create(PanelFrame,  TI.Back(0.28), { Size = UDim2.new(0.5, -4, 0, 28 + targetH) })
            t1:Play(); t2:Play(); t1.Completed:Wait()
        end
        animating = false
    end

    Header.Activated:Connect(function() SetCollapsed(not collapsed) end)

    -- Initialise size on next frame (content may not be laid out yet)
    task.defer(updateHeight)

    -- ── Panel public API ─────────────────────────────────────────────────────
    local Panel = {}
    function Panel:Collapse()    SetCollapsed(true)              end
    function Panel:Expand()      SetCollapsed(false)             end
    function Panel:Toggle()      SetCollapsed(not collapsed)     end
    function Panel:SetTitle(t)   HeaderLabel.Text = t            end
    function Panel:Visible(Bool) Funcs:ToggleVisible(PanelFrame, Bool) end
    function Panel:Destroy()     PanelFrame:Destroy()            end

    -- Full element API — all route through Content frame
    function Panel:AddSection(cfg)       return CreateSection(Content, cfg)                            end
    function Panel:AddSeparator()        return CreateSeparator(Content)                               end
    function Panel:AddParagraph(cfg)     return CreateParagraph(Content, cfg)                          end
    function Panel:AddButton(cfg)        return CreateButton(Content, cfg)                             end
    function Panel:AddToggle(cfg)        return CreateToggle(Content, cfg)                             end
    function Panel:AddDropdown(cfg)      return CreateDropdown(Content, cfg, dropdownHolder)           end
    function Panel:AddSlider(cfg)        return CreateSlider(Content, cfg)                             end
    function Panel:AddTextBox(cfg)       return CreateTextBox(Content, cfg)                            end
    function Panel:AddKeybind(cfg)       return CreateKeybind(Content, cfg)                            end
    function Panel:AddColorPicker(cfg)   return CreateColorPicker(Content, cfg)                        end
    function Panel:AddDiscordInvite(cfg) return CreateDiscordInvite(Content, cfg)                      end

    return Panel
end

