-- ── Drag helpers ──────────────────────────────────────────────────────────────
local function MakeWindowDrag(Inst, TabScrollFrame, TopBar)
    task.spawn(function()
        SetProps(Inst, { Active = true, AutoButtonColor = false })
        local Dragging, DragStart, StartPos = false, nil, nil
        Inst.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
            and input.UserInputType ~= Enum.UserInputType.Touch then return end
            local mousePos = UserInputService:GetMouseLocation()
            if TabScrollFrame and TabScrollFrame.Visible then
                local ap, as = TabScrollFrame.AbsolutePosition, TabScrollFrame.AbsoluteSize
                if mousePos.X >= ap.X-5 and mousePos.X <= ap.X+as.X+5
                and mousePos.Y >= ap.Y-5 and mousePos.Y <= ap.Y+as.Y+5 then return end            end
            if TopBar then
                local tp, ts = TopBar.AbsolutePosition, TopBar.AbsoluteSize
                if not (mousePos.X >= tp.X and mousePos.X <= tp.X+ts.X
                    and mousePos.Y >= tp.Y and mousePos.Y <= tp.Y+ts.Y) then return end
            end
            Dragging = true; DragStart = mousePos; StartPos = Inst.Position
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then Dragging = false end
        end)
        RunService.Heartbeat:Connect(function()
            if not Dragging then return end
            local d = UserInputService:GetMouseLocation() - DragStart
            Inst.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + d.X/UIScale,
                                      StartPos.Y.Scale, StartPos.Y.Offset + d.Y/UIScale)
        end)
    end)
    return Inst
end

