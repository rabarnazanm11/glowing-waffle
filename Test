                Window:Minimize()
            end
            pressing = false; wasDragged = false; dragStart = nil
        end)
        ConnectionManager:Connect(RunService.Heartbeat, function()            if not pressing or not dragStart then return end
            local delta = UserInputService:GetMouseLocation() - dragStart
            if delta.Magnitude >= THRESHOLD then
                wasDragged = true
                Pill.Position = UDim2.fromOffset(startOffset.X + delta.X, startOffset.Y + delta.Y)
            end
        end)
        return Pill
    end

    -- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
    --  MakeTab
    -- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
    local ContainerList = {}

    function Window:MakeTab(Configs)
        if type(Configs) ~= "table" then Configs = { Configs } end
        local TName = Configs[1] or Configs.Title or Configs.Name or "Tab"
        local TIcon = Configs[2] or Configs.Icon  or ""
        TIcon = redzlib:GetIcon(TIcon)
        if not TIcon:find("rbxassetid://") or #TIcon:gsub("rbxassetid://", "") < 6 then TIcon = false end

        local TabSelect = Make("Button", MainScroll, { Size = UDim2.new(1, 0, 0, 24) })
        Make("Corner", TabSelect)
        local isFirst = not FirstTab
        local LabelTitle = InsertTheme(Create("TextLabel", TabSelect, {
            Size = UDim2.new(1, TIcon and -25 or -15, 1),
            Position = UDim2.fromOffset(TIcon and 25 or 15),
            BackgroundTransparency = 1, Font = Enum.Font.GothamMedium,
            Text = TName, TextColor3 = Theme["Color Text"], TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTransparency = isFirst and 0 or 0.3, TextTruncate = "AtEnd",
        }), "Text")
        local LabelIcon = InsertTheme(Create("ImageLabel", TabSelect, {
            Position = UDim2.new(0, 8, 0.5), Size = UDim2.new(0, 13, 0, 13),
            AnchorPoint = Vector2.new(0, 0.5), Image = TIcon or "",
            BackgroundTransparency = 1, ImageTransparency = isFirst and 0 or 0.3,
        }), "Text")
        local Selected = InsertTheme(Create("Frame", TabSelect, {
            Size = isFirst and UDim2.new(0,4,0,13) or UDim2.new(0,4,0,4),
            Position = UDim2.new(0, 1, 0.5), AnchorPoint = Vector2.new(0, 0.5),
            BackgroundColor3 = Theme["Color Theme"],
            BackgroundTransparency = isFirst and 0 or 1,
        }), "Theme")
        Make("Corner", Selected, UDim.new(0.5, 0))

        local Container = InsertTheme(Create("ScrollingFrame", {
            Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0, 0, 1),
            AnchorPoint = Vector2.new(0, 1), ScrollBarThickness = 1.5,
            BackgroundTransparency = 1, ScrollBarImageTransparency = 0.2,            ScrollBarImageColor3 = Theme["Color Theme"], AutomaticCanvasSize = "Y",
            ScrollingDirection = "Y", BorderSizePixel = 0, CanvasSize = UDim2.new(),
            Name = ("Container %i [%s]"):format(#ContainerList + 1, TName),
        }, {
            Create("UIPadding", {
                PaddingLeft = UDim.new(0,10), PaddingRight  = UDim.new(0,10),
                PaddingTop  = UDim.new(0,10), PaddingBottom = UDim.new(0,10),
            }),
            Create("UIListLayout", { Padding = UDim.new(0, 5) }),
        }), "ScrollBar")
        table.insert(ContainerList, Container)
        if not FirstTab then Container.Parent = Containers end

        local function EnableTab()
            if Container.Parent then return end
            for _, Frame in ipairs(ContainerList) do
                if Frame:IsA("ScrollingFrame") and Frame ~= Container then Frame.Parent = nil end
            end
            Container.Parent = Containers
            Container.Size = UDim2.new(1, 0, 1, 0)
            Container.BackgroundTransparency = 1
            for _, child in ipairs(Container:GetDescendants()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("Frame") then
                    if child.BackgroundTransparency < 1 then
                        local origT = child.BackgroundTransparency
                        child.BackgroundTransparency = 1
                        FastTween(child, { BackgroundTransparency = origT }, 0.2, Enum.EasingStyle.Quad)
                    end
                end
            end
            for _, Tab in pairs(redzlib.Tabs) do
                if Tab.Cont ~= Container then Tab.func:Disable() end
            end
            FastTween(LabelTitle, { TextTransparency = 0    }, 0.3, Enum.EasingStyle.Quint)
            FastTween(LabelIcon,  { ImageTransparency = 0   }, 0.3, Enum.EasingStyle.Quint)
            FastTween(Selected,   { Size = UDim2.new(0,4,0,13), BackgroundTransparency = 0 }, 0.3, Enum.EasingStyle.Back)
        end
        ConnectionManager:Connect(TabSelect.Activated, EnableTab)
        FirstTab = true

        local Tab = {}
        table.insert(redzlib.Tabs, { TabInfo = { Name = TName, Icon = TIcon }, func = Tab, Cont = Container })
        Tab.Cont = Container

        function Tab:Disable()
            Container.Parent = nil
            FastTween(LabelTitle, { TextTransparency = 0.3               }, 0.3, Enum.EasingStyle.Quint)
            FastTween(LabelIcon,  { ImageTransparency = 0.3              }, 0.3, Enum.EasingStyle.Quint)
            FastTween(Selected,   { Size = UDim2.new(0,4,0,4), BackgroundTransparency = 1 }, 0.3, Enum.EasingStyle.Quint)
        end        function Tab:Enable()  EnableTab() end
        function Tab:Visible(Bool)
            Funcs:ToggleVisible(TabSelect, Bool)
            if Bool ~= nil then Container.Parent = Bool and Containers or nil end
        end
        function Tab:Destroy() TabSelect:Destroy(); Container:Destroy() end

        function Tab:AddSection(cfg)       return CreateSection(Container, cfg)                          end
        function Tab:AddSeparator()        return CreateSeparator(Container)                             end
        function Tab:AddParagraph(cfg)     return CreateParagraph(Container, cfg)                        end
        function Tab:AddButton(cfg)        return CreateButton(Container, cfg)                           end
        function Tab:AddToggle(cfg)        return CreateToggle(Container, cfg)                           end
        function Tab:AddDropdown(cfg)      return CreateDropdown(Container, cfg, DropdownHolder)         end
        function Tab:AddSlider(cfg)        return CreateSlider(Container, cfg)                           end
        function Tab:AddTextBox(cfg)       return CreateTextBox(Container, cfg)                          end
        function Tab:AddKeybind(cfg)       return CreateKeybind(Container, cfg)                          end
        function Tab:AddColorPicker(cfg)   return CreateColorPicker(Container, cfg)                      end
        function Tab:AddDiscordInvite(cfg) return CreateDiscordInvite(Container, cfg)                    end

        function Tab:AddHorizontalPanels(leftTitle, rightTitle)
            local HFrame = Create("Frame", Container, {
                Size                 = UDim2.new(1, 0, 0, 0),
                AutomaticSize        = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
                Name                 = "HorizontalPanels",
            })
            Create("UIListLayout", HFrame, {
                FillDirection       = Enum.FillDirection.Horizontal,
                HorizontalAlignment = Enum.HorizontalAlignment.Center,
                VerticalAlignment   = Enum.VerticalAlignment.Top,
                Padding             = UDim.new(0, 8),
                SortOrder           = Enum.SortOrder.LayoutOrder,
            })
            local LeftPanel  = CreatePanel(HFrame, leftTitle  or "Left",  DropdownHolder)
            local RightPanel = CreatePanel(HFrame, rightTitle or "Right", DropdownHolder)
            return LeftPanel, RightPanel
        end

        return Tab
    end

    ConnectionManager:Connect(CloseButton.Activated, function()    Window:CloseBtn()    end)
    ConnectionManager:Connect(MinimizeButton.Activated, function() Window:MinimizeBtn() end)
    return Window
end

return redzlib
