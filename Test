function redzlib:SetTheme(NewTheme)
    if not VerifyTheme(NewTheme) then return end
    Connection:FireConnection("ThemeChanging", NewTheme)
    redzlib.Save.Theme = NewTheme
    SaveJson("redz library V5.json", redzlib.Save)
    Theme = redzlib.Themes[NewTheme]
    for _, Val in ipairs(redzlib.Instances) do
        local inst, t = Val.Instance, Val.Type
        if not inst or not inst.Parent then continue end
        pcall(function()
            if     t == "Gradient"  then inst.Color                = Theme["Color Hub 1"]
            elseif t == "Frame"     then inst.BackgroundColor3     = Theme["Color Hub 2"]
            elseif t == "Stroke"    then inst[GetColor(inst)]      = Theme["Color Stroke"]
            elseif t == "Theme"     then inst[GetColor(inst)]      = Theme["Color Theme"]
            elseif t == "Text"      then inst[GetColor(inst)]      = Theme["Color Text"]
            elseif t == "DarkText"  then inst[GetColor(inst)]      = Theme["Color Dark Text"]
            elseif t == "ScrollBar" then inst.ScrollBarImageColor3 = Theme["Color Theme"]
            end
        end)
    end
    Connection:FireConnection("ThemeChanged", NewTheme)
end

function redzlib:VerifyTheme(Name) return VerifyTheme(Name) end

function redzlib:SetScale(NewScale)
    local s = ViewportSize.Y / math.clamp(NewScale, 300, 2000)
    UIScale = s
    if ScreenGui:FindFirstChild("Scale") then ScreenGui.Scale.Scale = s end
end

