local function CreateToggle(parent, configs)
    local TName    = configs[1] or configs.Name  or configs.Title or "Toggle"
    local TDesc    = configs.Desc or configs.Description or ""
    local Callback = Funcs:GetCallback(configs, 3)
    local Flag     = configs[4] or configs.Flag or false
    local Default  = configs[2]
    if Default == nil then Default = configs.Default end
    if Default == nil then Default = false end
    if CheckFlag(Flag) then Default = GetFlag(Flag) end

    local Button, LabelFunc = ButtonFrame(parent, TName, TDesc, UDim2.new(1, -38))
    local ToggleHolder = InsertTheme(Create("Frame", Button, {
        Size             = UDim2.new(0, 35, 0, 18),
        Position         = UDim2.new(1, -10, 0.5),
        AnchorPoint      = Vector2.new(1, 0.5),
        BackgroundColor3 = Theme["Color Stroke"],
    }), "Stroke")
    Make("Corner", ToggleHolder, UDim.new(0.5, 0))
    local Slider = Create("Frame", ToggleHolder, {
        BackgroundTransparency = 1,
        Size        = UDim2.new(0.8, 0, 0.8, 0),
        Position    = UDim2.new(0.5, 0, 0.5, 0),        AnchorPoint = Vector2.new(0.5, 0.5),
    })
    local Toggle = InsertTheme(Create("Frame", Slider, {
        Size             = UDim2.new(0, 12, 0, 12),
        Position         = UDim2.new(0, 0, 0.5),
        AnchorPoint      = Vector2.new(0, 0.5),
        BackgroundColor3 = Theme["Color Theme"],
    }), "Theme")
    Make("Corner", Toggle, UDim.new(0.5, 0))

    local WaitToggle
    local function SetToggleVal(Val)
        if WaitToggle then return end
        WaitToggle, Default = true, Val
        SetFlag(Flag, Default)
        Funcs:FireCallback(Callback, Default)
        if Default then
            FastTween(ToggleHolder, { BackgroundColor3 = Theme["Color Theme"] }, 0.2, Enum.EasingStyle.Quint)
            FastTween(Toggle, { Position = UDim2.new(1,0,0.5), AnchorPoint = Vector2.new(1,0.5), BackgroundTransparency = 0 }, 0.25, Enum.EasingStyle.Back)
        else
            FastTween(ToggleHolder, { BackgroundColor3 = Theme["Color Stroke"] }, 0.2, Enum.EasingStyle.Quint)
            FastTween(Toggle, { Position = UDim2.new(0,0,0.5), AnchorPoint = Vector2.new(0,0.5), BackgroundTransparency = 0.8 }, 0.25, Enum.EasingStyle.Quint)
        end
        WaitToggle = false
    end
    task.spawn(SetToggleVal, Default)
    ConnectionManager:Connect(Button.Activated, function() SetToggleVal(not Default) end)

    local ToggleObj = {}
    function ToggleObj:Visible(...)  Funcs:ToggleVisible(Button, ...) end
    function ToggleObj:Destroy()     Button:Destroy()                 end
    function ToggleObj:Callback(...) Funcs:InsertCallback(Callback, ...) end
    function ToggleObj:Set(Val1, Val2)
        if type(Val1)=="string" and type(Val2)=="string" then LabelFunc:SetTitle(Val1); LabelFunc:SetDesc(Val2)
        elseif type(Val1)=="string"   then LabelFunc:SetTitle(Val1)
        elseif type(Val1)=="boolean"  then
            if WaitToggle and Val2 then repeat task.wait() until not WaitToggle end
            task.spawn(SetToggleVal, Val1)
        elseif type(Val1)=="function" then Callback = { Val1 } end
    end
    return ToggleObj
end

local function CreateDropdown(parent, configs, dropdownHolder)
    local DName        = configs[1] or configs.Name  or configs.Title or "Dropdown"
    local DDesc        = configs.Desc or configs.Description or ""
    local DOptions     = configs[2] or configs.Options  or {}
    local OpDefault    = configs[3] or configs.Default  or {}
    local Flag         = configs[5] or configs.Flag     or false
    local DMultiSelect = configs.MultiSelect            or false    local Callback     = Funcs:GetCallback(configs, 4)
    local Button, LabelFunc = ButtonFrame(parent, DName, BDesc, UDim2.new(1, -180))
    local SelectedFrame = InsertTheme(Create("Frame", Button, {
        Size             = UDim2.new(0, 150, 0, 18),
        Position         = UDim2.new(1, -10, 0.5),
        AnchorPoint      = Vector2.new(1, 0.5),
        BackgroundColor3 = Theme["Color Stroke"],
    }), "Stroke")
    Make("Corner", SelectedFrame, UDim.new(0, 4))
    local ActiveLabel = InsertTheme(Create("TextLabel", SelectedFrame, {
        Size                 = UDim2.new(1, -20, 1, 0),
        AnchorPoint          = Vector2.new(0, 0.5),
        Position             = UDim2.new(0, 6, 0.5, 0),
        BackgroundTransparency = 1,
        Font                 = Enum.Font.GothamBold,
        TextSize             = 9,
        TextTruncate         = "AtEnd",
        TextColor3           = Theme["Color Text"],
        TextXAlignment       = "Left",
        Text                 = "...",
    }), "Text")
    local Arrow = Create("ImageLabel", SelectedFrame, {
        Size                 = UDim2.new(0, 14, 0, 14),
        Position             = UDim2.new(1, -3, 0.5),
        AnchorPoint          = Vector2.new(1, 0.5),
        Image                = "rbxassetid://10709791523",
        BackgroundTransparency = 1,
    })
    local NoClickFrame = Create("TextButton", dropdownHolder, {
        Name = "AntiClick", Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1, Visible = false, Text = "",
    })
    local DropFrame = Create("Frame", NoClickFrame, {
        Size                 = UDim2.fromOffset(152, 0),
        BackgroundTransparency = 0.08,
        BackgroundColor3     = Color3.fromRGB(255, 255, 255),
        AnchorPoint          = Vector2.new(0, 1),
        Name                 = "DropdownFrame",
        ClipsDescendants     = true,
        Active               = true,
        ZIndex               = 50,
    })
    Make("Corner",   DropFrame)
    Make("Stroke",   DropFrame)
    Make("Gradient", DropFrame, { Rotation = 60 })
    local ScrollFrame = InsertTheme(Create("ScrollingFrame", DropFrame, {
        ScrollBarImageColor3 = Theme["Color Theme"],
        Size                 = UDim2.new(1, 0, 1, 0),
        ScrollBarThickness   = 1.5,
        BackgroundTransparency = 1,        BorderSizePixel      = 0,
        CanvasSize           = UDim2.new(),
        ScrollingDirection   = "Y",
        AutomaticCanvasSize  = "Y",
        Active               = true,
        ZIndex               = 51,
    }, {
        Create("UIPadding", {
            PaddingLeft   = UDim.new(0, 8),
            PaddingRight  = UDim.new(0, 8),
            PaddingTop    = UDim.new(0, 5),
            PaddingBottom = UDim.new(0, 5),
        }),
        Create("UIListLayout", { Padding = UDim.new(0, 4) }),
    }), "ScrollBar")
    local ScrollSize, WaitDrop = 5
    local function CloseDropdown()
        WaitDrop = true
        FastTween(Arrow,     { Rotation = 0 },                            0.18, Enum.EasingStyle.Quint)
        FastTween(DropFrame, { Size = UDim2.fromOffset(152, 0) },         0.2,  Enum.EasingStyle.Quint)
        FastTween(Arrow,     { ImageColor3 = Color3.fromRGB(255,255,255) }, 0.18)
        Arrow.Image = "rbxassetid://10709791523"
        NoClickFrame.Visible = false
        WaitDrop = false
    end
    local function GetDropSize() return UDim2.fromOffset(152, ScrollSize) end
    local function CalculateSize()
        local count = 0
        for _, child in ipairs(ScrollFrame:GetChildren()) do
            if child:IsA("Frame") or child:IsA("TextButton") then count += 1 end
        end
        ScrollSize = (math.clamp(count, 0, 10) * 25) + 10
        if NoClickFrame.Visible then FastTween(DropFrame, { Size = GetDropSize() }, 0.2) end
    end
    local function ToggleDropdown()
        if WaitDrop then return end
        WaitDrop = true
        if NoClickFrame.Visible then
            Arrow.Image = "rbxassetid://10709791523"
            FastTween(Arrow,     { ImageColor3 = Color3.fromRGB(255,255,255) }, 0.18)
            FastTween(DropFrame, { Size = UDim2.fromOffset(152, 0) },           0.2)
            task.delay(0.21, function() NoClickFrame.Visible = false end)
        else
            NoClickFrame.Visible = true
            Arrow.Image = "rbxassetid://10709790948"
            FastTween(Arrow,     { ImageColor3 = Theme["Color Theme"] }, 0.18)
            FastTween(DropFrame, { Size = GetDropSize() },               0.2)
        end
        WaitDrop = false
    end    local function CalculatePos()
        local fp   = SelectedFrame.AbsolutePosition
        local ss   = ScreenGui.AbsoluteSize
        local cx   = math.clamp(fp.X/UIScale, 0, ss.X/UIScale - 152)
        local cy   = math.clamp(fp.Y/UIScale, 0, ss.Y/UIScale)
        local anch = fp.Y > ss.Y/1.4 and 1 or ScrollSize > 80 and 0.5 or 0
        DropFrame.AnchorPoint = Vector2.new(0, anch)
        FastTween(DropFrame, { Position = UDim2.fromOffset(cx, cy) }, 0.1)
    end
    local DropSelected, Options, AddOption, RemoveOption, AddNewOptions
    local MultiSelect = DMultiSelect
    do
        Options = {}
        local defaultRaw = type(OpDefault) ~= "table" and { OpDefault } or OpDefault
        DropSelected = MultiSelect and {} or (CheckFlag(Flag) and GetFlag(Flag) or defaultRaw[1])
        if MultiSelect then
            for idx, val in pairs(CheckFlag(Flag) and GetFlag(Flag) or defaultRaw) do
                local name = type(idx) == "string" and idx or tostring(val)
                DropSelected[name] = true
            end
        end
        local function FireCB()
            SetFlag(Flag, MultiSelect and DropSelected or tostring(DropSelected))
            Funcs:FireCallback(Callback, DropSelected)
        end
        local function UpdateLabel()
            if MultiSelect then
                local p = {}
                for k,v in pairs(DropSelected) do if v then table.insert(p, k) end end
                ActiveLabel.Text = #p > 0 and table.concat(p, ", ") or "..."
            else
                ActiveLabel.Text = tostring(DropSelected or "...")
            end
        end
        local function UpdateSelected()
            for _, v in pairs(Options) do
                local nodes  = v.nodes
                local active = MultiSelect and (DropSelected[v.Name] == true) or (v.Value == DropSelected)
                FastTween(nodes[2], { BackgroundTransparency = active and 0 or (MultiSelect and 0.8 or 1) }, 0.25)
                FastTween(nodes[2], { Size = active and UDim2.fromOffset(4,12) or UDim2.fromOffset(4,4) }, 0.25)
                FastTween(nodes[3], { TextTransparency = active and 0 or 0.4 }, 0.25)
            end
            UpdateLabel()
        end
        local function SelectOption(opt)
            if MultiSelect then opt.Stats = not opt.Stats; DropSelected[opt.Name] = opt.Stats
            else DropSelected = opt.Value end
            FireCB(); UpdateSelected()
        end
        AddOption = function(idx, val)            local name = tostring(type(idx) == "string" and idx or val)
            if Options[name] then return end
            Options[name] = { index = idx, Value = val or idx, Name = name, Stats = false }
            if MultiSelect then
                local s = DropSelected[name]
                DropSelected[name] = s or false
                Options[name].Stats = s or false
            end
            local Btn = Make("Button", ScrollFrame, { Name = "DropBtn_"..name, Size = UDim2.new(1,0,0,21), ZIndex = 52 })
            Make("Corner", Btn, UDim.new(0, 4))
            local Indicator = InsertTheme(Create("Frame", Btn, {
                Position         = UDim2.new(0, 1, 0.5),
                Size             = UDim2.fromOffset(4, 4),
                BackgroundColor3 = Theme["Color Theme"],
                BackgroundTransparency = 1,
                AnchorPoint      = Vector2.new(0, 0.5),
                ZIndex           = 53,
            }), "Theme")
            Make("Corner", Indicator, UDim.new(0.5, 0))
            local NameLabel = InsertTheme(Create("TextLabel", Btn, {
                Size                 = UDim2.new(1, 0, 1),
                Position             = UDim2.new(0, 10),
                Text                 = name,
                TextColor3           = Theme["Color Text"],
                Font                 = Enum.Font.GothamBold,
                TextXAlignment       = "Left",
                BackgroundTransparency = 1,
                TextTransparency     = 0.4,
                ZIndex               = 53,
            }), "Text")
            ConnectionManager:Connect(Btn.Activated, function() SelectOption(Options[name]) end)
            Options[name].nodes = { Btn, Indicator, NameLabel }
            Connection:FireConnection("OptionAdded", name)
        end
        RemoveOption = function(name)
            name = tostring(name)
            local opt = Options[name]
            if not opt then return end
            if MultiSelect then DropSelected[name] = nil else DropSelected = nil end
            pcall(opt.nodes[1].Destroy, opt.nodes[1])
            Options[name] = nil
        end
        AddNewOptions = function(List, Clear)
            if Clear then for name in pairs(Options) do RemoveOption(name) end end
            for idx, val in pairs(List) do AddOption(idx, val) end
            FireCB(); UpdateSelected()
        end
        for idx, val in pairs(DOptions) do AddOption(idx, val) end
        FireCB(); UpdateSelected()
    end    ConnectionManager:Connect(Button.Activated, ToggleDropdown)
    ConnectionManager:Connect(NoClickFrame.MouseButton1Down, CloseDropdown)
    ConnectionManager:Connect(NoClickFrame.MouseButton1Click, CloseDropdown)
    ConnectionManager:Connect(ScreenGui:GetPropertyChangedSignal("AbsoluteSize"), CloseDropdown)
    ConnectionManager:Connect(SelectedFrame:GetPropertyChangedSignal("AbsolutePosition"), CalculatePos)
    ConnectionManager:Connect(Button.Activated, CalculateSize)
    ConnectionManager:Connect(ScrollFrame.ChildAdded, CalculateSize)
    ConnectionManager:Connect(ScrollFrame.ChildRemoved, CalculateSize)
    CalculatePos(); CalculateSize()
    local Dropdown = {}
    function Dropdown:Visible(...)  Funcs:ToggleVisible(Button, ...)                                          end
    function Dropdown:Destroy()     Button:Destroy()                                                          end
    function Dropdown:Callback(...) Funcs:InsertCallback(Callback,...); Funcs:FireCallback(Callback, DropSelected) end
    function Dropdown:GetSelected() return DropSelected                                                       end
    function Dropdown:Refresh(List) if type(List)=="table" then AddNewOptions(List, true) end                 end
    function Dropdown:Add(...)
        local args = { ... }
        if type(args[1]) == "table" then for _, name in ipairs(args[1]) do AddOption(name) end
        else for _, name in ipairs(args) do AddOption(name) end end
    end
    function Dropdown:Remove(OptionName) RemoveOption(tostring(OptionName)) end
    function Dropdown:Set(Val1)
        if type(Val1) == "table" then
            if MultiSelect then
                for k in pairs(DropSelected) do DropSelected[k] = false end
                for _, name in ipairs(Val1) do
                    if Options[tostring(name)] then DropSelected[tostring(name)] = true; Options[tostring(name)].Stats = true end
                end
            else DropSelected = Val1[1] or nil end
            SetFlag(Flag, MultiSelect and DropSelected or tostring(DropSelected))
            Funcs:FireCallback(Callback, DropSelected)
            for _, v in pairs(Options) do
                local active = MultiSelect and (DropSelected[v.Name] == true) or (v.Value == DropSelected)
                pcall(function()
                    FastTween(v.nodes[2], { BackgroundTransparency = active and 0 or (MultiSelect and 0.8 or 1) }, 0.2)
                    FastTween(v.nodes[2], { Size = active and UDim2.fromOffset(4,12) or UDim2.fromOffset(4,4) }, 0.2)
                    FastTween(v.nodes[3], { TextTransparency = active and 0 or 0.4 }, 0.2)
                end)
            end
            if MultiSelect then
                local p = {}
                for k,v in pairs(DropSelected) do if v then table.insert(p, k) end end
                ActiveLabel.Text = #p > 0 and table.concat(p, ", ") or "..."
            else ActiveLabel.Text = tostring(DropSelected or "...") end
        elseif type(Val1) == "function" then Callback = { Val1 } end
    end
    return Dropdown
end

